    pass NIL;
};

pub func:draw_sprite_ext = NIL(int32:handle, flt32:x, flt32:y, flt32:xscale, flt32:yscale, flt32:rot) {
    aria_gml_draw_sprite_ext(handle, x, y, xscale, yscale, rot);
    pass NIL;
