extern func:aria_gml_mouse_check_button_pressed   = int32(int32:btn);
extern func:aria_gml_mouse_check_button_released  = int32(int32:btn);
extern func:aria_gml_mouse_wheel                  = flt32();

// ── random ──
extern func:aria_gml_randomize       = void(int32:seed);
