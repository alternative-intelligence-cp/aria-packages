    pass NIL;
};

pub func:draw_rectangle = NIL(flt32:x1, flt32:y1, flt32:x2, flt32:y2, int32:outline) {
    aria_gml_draw_rectangle(x1, y1, x2, y2, outline);
    pass NIL;
};

pub func:draw_circle = NIL(flt32:x, flt32:y, flt32:radius, int32:outline) {
    aria_gml_draw_circle(x, y, radius, outline);
    pass NIL;
};

pub func:draw_triangle = NIL(flt32:x1, flt32:y1, flt32:x2, flt32:y2, flt32:x3, flt32:y3, int32:outline) {
    aria_gml_draw_triangle(x1, y1, x2, y2, x3, y3, outline);
    pass NIL;
};

pub func:draw_line = NIL(flt32:x1, flt32:y1, flt32:x2, flt32:y2) {
    aria_gml_draw_line(x1, y1, x2, y2);
    pass NIL;
};

pub func:draw_line_width = NIL(flt32:x1, flt32:y1, flt32:x2, flt32:y2, flt32:width) {
    aria_gml_draw_line_width(x1, y1, x2, y2, width);
    pass NIL;
};

pub func:draw_point = NIL(flt32:x, flt32:y) {
    aria_gml_draw_point(x, y);
    pass NIL;
};

pub func:draw_text = NIL(flt32:x, flt32:y, string:text) {
    aria_gml_draw_text(x, y, text);
    pass NIL;
};

pub func:string_width = int32(string:text) {
    int32:result = aria_gml_string_width(text);
    pass result;
};

pub func:draw_text_ext = NIL(flt32:x, flt32:y, string:text, int32:font_size) {
    aria_gml_draw_text_ext(x, y, text, font_size);
    pass NIL;
};

