    pass NIL;
};

pub func:game_set_target_fps = NIL(int32:fps) {
    aria_gml_game_set_target_fps(fps);
    pass NIL;
};

pub func:game_get_fps = int32() {
    int32:result = aria_gml_game_get_fps();
    pass result;
};

pub func:game_get_time = flt32() {
    flt32:result = aria_gml_game_get_time();
    pass result;
};

pub func:delta_time = flt32() {
    flt32:result = aria_gml_game_get_frame_time();
    pass result;
};

// ── Drawing primitives ──

pub func:draw_clear = NIL(int32:col) {
