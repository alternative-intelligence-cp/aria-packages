// ── music ──
extern func:aria_gml_music_load        = int32(string:path);
extern func:aria_gml_music_delete      = void(int32:handle);
extern func:aria_gml_music_play        = void(int32:handle);
extern func:aria_gml_music_stop        = void(int32:handle);
