extern func:aria_gml_window_get_height = int32();

// ═══════════════════════════════════════════════════════════════════════
// Public API — GML-named wrappers
// ═══════════════════════════════════════════════════════════════════════

// ── Color helpers ──

pub func:make_color_rgb = int32(int32:r, int32:g, int32:b) {
    int32:result = aria_gml_make_color_rgb(r, g, b);
    pass result;
};

pub func:color_get_red = int32(int32:col) {
    int32:result = aria_gml_color_get_red(col);
    pass result;
};

pub func:color_get_green = int32(int32:col) {
    int32:result = aria_gml_color_get_green(col);
    pass result;
};

pub func:color_get_blue = int32(int32:col) {
    int32:result = aria_gml_color_get_blue(col);
    pass result;
};

// ── Draw state ──

pub func:draw_set_color = NIL(int32:col) {
    aria_gml_draw_set_color(col);
    pass NIL;
};

pub func:draw_set_alpha = NIL(flt32:alpha) {
    aria_gml_draw_set_alpha(alpha);
    pass NIL;
};

pub func:draw_get_color = int32() {
    int32:result = aria_gml_draw_get_color();
    pass result;
};

pub func:draw_get_alpha = flt32() {
    flt32:result = aria_gml_draw_get_alpha();
    pass result;
};

pub func:draw_set_font_size = NIL(int32:size) {
    aria_gml_draw_set_font_size(size);
    pass NIL;
};

// ── Game loop ──

pub func:game_init = NIL(int32:w, int32:h, string:title) {
    aria_gml_game_init(w, h, title);
    pass NIL;
};

pub func:game_should_close = int32() {
    int32:result = aria_gml_game_should_close();
    pass result;
};

pub func:game_begin_step = NIL() {
    aria_gml_game_begin_step();
