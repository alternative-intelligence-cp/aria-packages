};

pub func:game_begin_draw = NIL() {
    aria_gml_game_begin_draw();
    pass NIL;
};

pub func:game_end_draw = NIL() {
    aria_gml_game_end_draw();
    pass NIL;
};

pub func:game_shutdown = NIL() {
