// aria_gml.aria — GameMaker Language compatibility layer for Aria
//
// Provides GML-style function names and semantics over raylib.
// Usage: compile with  -L path/to/shim -laria_gml_shim -lraylib -lm
//
// Key GML conventions preserved:
//   - draw_set_color() persists across draw calls
//   - Colors packed as r | (g<<8) | (b<<16)
//   - Rectangles use (x1,y1)-(x2,y2) corners
//   - outline param: 0i32 = filled, 1i32 = outline

func:failsafe = int32(tbb32:err) {
    exit 1;
};

// ═══════════════════════════════════════════════════════════════════════
// Color Constants (GML-standard, packed as r | g<<8 | b<<16)
// ═══════════════════════════════════════════════════════════════════════

int32:c_black   = 0i32;
int32:c_white   = 16777215i32;
int32:c_red     = 255i32;
int32:c_green   = 65280i32;
int32:c_blue    = 16711680i32;
int32:c_yellow  = 65535i32;
int32:c_orange  = 4235519i32;
int32:c_purple  = 16711935i32;
int32:c_fuchsia = 16711935i32;
int32:c_aqua    = 16776960i32;
int32:c_teal    = 8421376i32;
int32:c_maroon  = 128i32;
int32:c_navy    = 8388608i32;
int32:c_olive   = 32896i32;
int32:c_gray    = 8421504i32;
int32:c_ltgray  = 12632256i32;
int32:c_dkgray  = 4210752i32;
int32:c_silver  = 12632256i32;

// ═══════════════════════════════════════════════════════════════════════
// Keyboard Constants (raylib KEY_ values matching GML vk_ names)
// ═══════════════════════════════════════════════════════════════════════

int32:vk_left      = 263i32;
int32:vk_right     = 262i32;
int32:vk_up        = 265i32;
int32:vk_down      = 264i32;
int32:vk_space     = 32i32;
int32:vk_enter     = 257i32;
int32:vk_escape    = 256i32;
int32:vk_backspace = 259i32;
int32:vk_tab       = 258i32;
int32:vk_shift     = 340i32;
int32:vk_control   = 341i32;
int32:vk_alt       = 342i32;
int32:vk_delete    = 261i32;
int32:vk_insert    = 260i32;
int32:vk_home      = 268i32;
int32:vk_pageup    = 266i32;
int32:vk_pagedown  = 267i32;

// Letter keys (A-Z, ASCII values work with raylib)
int32:vk_a = 65i32;
int32:vk_b = 66i32;
int32:vk_c = 67i32;
int32:vk_d = 68i32;
int32:vk_e = 69i32;
int32:vk_f = 70i32;
int32:vk_g = 71i32;
int32:vk_h = 72i32;
int32:vk_i = 73i32;
int32:vk_j = 74i32;
int32:vk_k = 75i32;
int32:vk_l = 76i32;
int32:vk_m = 77i32;
int32:vk_n = 78i32;
int32:vk_o = 79i32;
int32:vk_p = 80i32;
int32:vk_q = 81i32;
int32:vk_r = 82i32;
int32:vk_s = 83i32;
int32:vk_t = 84i32;
int32:vk_u = 85i32;
int32:vk_v = 86i32;
int32:vk_w = 87i32;
int32:vk_x = 88i32;
int32:vk_y = 89i32;
int32:vk_z = 90i32;

// Number keys
int32:vk_0 = 48i32;
int32:vk_1 = 49i32;
int32:vk_2 = 50i32;
int32:vk_3 = 51i32;
int32:vk_4 = 52i32;
int32:vk_5 = 53i32;
int32:vk_6 = 54i32;
int32:vk_7 = 55i32;
int32:vk_8 = 56i32;
int32:vk_9 = 57i32;

// Mouse button constants
int32:mb_left   = 0i32;
int32:mb_right  = 1i32;
int32:mb_middle = 2i32;

// ═══════════════════════════════════════════════════════════════════════
// Extern declarations — link to aria_gml_shim
// ═══════════════════════════════════════════════════════════════════════

// ── color helpers ──
extern func:aria_gml_make_color_rgb    = int32(int32:r, int32:g, int32:b);
extern func:aria_gml_color_get_red     = int32(int32:col);
extern func:aria_gml_color_get_green   = int32(int32:col);
extern func:aria_gml_color_get_blue    = int32(int32:col);

// ── draw state ──
extern func:aria_gml_draw_set_color    = void(int32:col);
extern func:aria_gml_draw_set_alpha    = void(flt32:alpha);
extern func:aria_gml_draw_get_color    = int32();
extern func:aria_gml_draw_get_alpha    = flt32();
extern func:aria_gml_draw_set_font_size = void(int32:size);

// ── game loop ──
extern func:aria_gml_game_init         = void(int32:w, int32:h, string:title);
extern func:aria_gml_game_should_close = int32();
extern func:aria_gml_game_begin_step   = void();
extern func:aria_gml_game_begin_draw   = void();
extern func:aria_gml_game_end_draw     = void();
extern func:aria_gml_game_shutdown     = void();
extern func:aria_gml_game_set_target_fps = void(int32:fps);
extern func:aria_gml_game_get_fps      = int32();
extern func:aria_gml_game_get_time     = flt32();
extern func:aria_gml_game_get_frame_time = flt32();

// ── drawing primitives ──
extern func:aria_gml_draw_clear        = void(int32:col);
extern func:aria_gml_draw_rectangle    = void(flt32:x1, flt32:y1, flt32:x2, flt32:y2, int32:outline);
extern func:aria_gml_draw_circle       = void(flt32:x, flt32:y, flt32:radius, int32:outline);
extern func:aria_gml_draw_triangle     = void(flt32:x1, flt32:y1, flt32:x2, flt32:y2, flt32:x3, flt32:y3, int32:outline);
extern func:aria_gml_draw_line         = void(flt32:x1, flt32:y1, flt32:x2, flt32:y2);
extern func:aria_gml_draw_line_width   = void(flt32:x1, flt32:y1, flt32:x2, flt32:y2, flt32:width);
extern func:aria_gml_draw_point        = void(flt32:x, flt32:y);
extern func:aria_gml_draw_text         = void(flt32:x, flt32:y, string:text);
extern func:aria_gml_string_width      = int32(string:text);
extern func:aria_gml_draw_text_ext     = void(flt32:x, flt32:y, string:text, int32:font_size);

// ── sprites ──
extern func:aria_gml_sprite_load       = int32(string:path);
extern func:aria_gml_sprite_delete     = void(int32:handle);
extern func:aria_gml_sprite_get_width  = int32(int32:handle);
extern func:aria_gml_sprite_get_height = int32(int32:handle);
extern func:aria_gml_draw_sprite       = void(int32:handle, flt32:x, flt32:y);
extern func:aria_gml_draw_sprite_ext   = void(int32:handle, flt32:x, flt32:y, flt32:xscale, flt32:yscale, flt32:rot);

