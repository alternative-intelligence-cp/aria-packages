// test_aria_rate_limit.aria — Tests for pure Aria rate limiter
use "../src/aria_rate_limit.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_libc_string" {
    func:aria_libc_string_strstr   = int64(string:haystack, string:needle);
    func:aria_libc_string_strcat   = string(string:a, string:b);
    func:aria_libc_string_from_i64 = string(int64:val);
}

func:main = int32() {
    println("=== aria-rate-limit tests ===");

    // Test 1: Default allows requests
    drop rate_limit_reset();
    int32:a1 = raw rate_limit_check("192.168.1.1");
    if (a1 == 1i32) { println("  PASS: default allows"); }
    else { println("  FAIL: default allows"); }

    // Test 2: Remaining tokens decrease
    drop rate_limit_reset();
    drop rate_limit_configure(5i32, 1i32, 60i32);
    _ = rate_limit_check("client1");
    int32:rem1 = raw rate_limit_remaining("client1");
    if (rem1 == 4i32) { println("  PASS: remaining after 1"); }
    else {
        string:m2 = aria_libc_string_strcat("  FAIL: remaining after 1 got=", aria_libc_string_from_i64(@cast<int64>(rem1)));
        println(m2);
    }

    // Test 3: Exhaust tokens
    _ = rate_limit_check("client1");
    _ = rate_limit_check("client1");
    _ = rate_limit_check("client1");
    _ = rate_limit_check("client1");
    int32:a2 = raw rate_limit_check("client1");
    if (a2 == 0i32) { println("  PASS: exhausted denied"); }
    else { println("  FAIL: exhausted denied"); }

    int32:rem2 = raw rate_limit_remaining("client1");
    if (rem2 == 0i32) { println("  PASS: remaining 0"); }
    else {
        string:m4 = aria_libc_string_strcat("  FAIL: remaining 0 got=", aria_libc_string_from_i64(@cast<int64>(rem2)));
        println(m4);
    }

    // Test 4: Different clients independent
    int32:a3 = raw rate_limit_check("client2");
    if (a3 == 1i32) { println("  PASS: client2 allowed"); }
    else { println("  FAIL: client2 allowed"); }

    // Test 5: Custom cost
    drop rate_limit_reset();
    drop rate_limit_configure(10i32, 1i32, 60i32);
    int32:a4 = raw rate_limit_check_cost("expensive", 5i32);
    if (a4 == 1i32) { println("  PASS: cost 5 allowed"); }
    else { println("  FAIL: cost 5 allowed"); }

    int32:rem3 = raw rate_limit_remaining("expensive");
    if (rem3 == 5i32) { println("  PASS: remaining after cost 5"); }
    else {
        string:m7 = aria_libc_string_strcat("  FAIL: remaining after cost 5 got=", aria_libc_string_from_i64(@cast<int64>(rem3)));
        println(m7);
    }

    int32:a5 = raw rate_limit_check_cost("expensive", 6i32);
    if (a5 == 0i32) { println("  PASS: cost 6 denied"); }
    else { println("  FAIL: cost 6 denied"); }

    // Test 6: Headers contain expected fields
    drop rate_limit_reset();
    drop rate_limit_configure(50i32, 5i32, 60i32);
    _ = rate_limit_check("hdr_client");
    string:hdrs = raw rate_limit_headers("hdr_client");
    int64:p1 = aria_libc_string_strstr(hdrs, "X-RateLimit-Limit: 50");
    if (p1 >= 0i64) { println("  PASS: header has limit"); }
    else { println("  FAIL: header has limit"); }

    int64:p2 = aria_libc_string_strstr(hdrs, "X-RateLimit-Remaining:");
    if (p2 >= 0i64) { println("  PASS: header has remaining"); }
    else { println("  FAIL: header has remaining"); }

    // Test 7: Headers include Retry-After when exhausted
    drop rate_limit_test_set_tokens("hdr_client", 0i32);
    string:hdrs2 = raw rate_limit_headers("hdr_client");
    int64:p3 = aria_libc_string_strstr(hdrs2, "Retry-After:");
    if (p3 >= 0i64) { println("  PASS: retry-after hdr"); }
    else { println("  FAIL: retry-after hdr"); }

    // Test 8: Set tokens to 0 check remaining
    drop rate_limit_reset();
    drop rate_limit_configure(10i32, 10i32, 60i32);
    drop rate_limit_test_set_tokens("refill_client", 0i32);
    int32:rem4 = raw rate_limit_remaining("refill_client");
    if (rem4 == 0i32) { println("  PASS: no refill yet"); }
    else {
        string:m8 = aria_libc_string_strcat("  FAIL: no refill yet got=", aria_libc_string_from_i64(@cast<int64>(rem4)));
        println(m8);
    }

    // Test 9: Reset clears all
    drop rate_limit_reset();
    int32:a6 = raw rate_limit_check("fresh");
    if (a6 == 1i32) { println("  PASS: fresh after reset"); }
    else { println("  FAIL: fresh after reset"); }

    println("=== 9 tests done ===");
    exit 0;
};
