// test_aria_template.aria — Template engine tests (7 tests)

use "../src/aria_template.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // T01: set variable
    int32:s1 = raw template_set("name", "Aria");
    if (s1 == 1i32) { drop println("[PASS] T01 set"); }
    if (s1 != 1i32) { drop println("[FAIL] T01 set"); }

    // T02: has variable
    int32:h1 = raw template_has("name");
    if (h1 == 1i32) { drop println("[PASS] T02 has"); }
    if (h1 != 1i32) { drop println("[FAIL] T02 has"); }

    // T03: count
    int32:s2 = raw template_set("version", "0.2.6");
    int32:cnt = raw template_count();
    if (cnt == 2i32) { drop println("[PASS] T03 count"); }
    if (cnt != 2i32) { drop println("[FAIL] T03 count"); }

    // T04: render single var
    string:r1 = raw template_render("Hello {{name}}!");
    int32:cmp4 = aria_libc_string_strcmp(r1, "Hello Aria!");
    if (cmp4 == 0i32) { drop println("[PASS] T04 render"); }
    if (cmp4 != 0i32) { drop println("[FAIL] T04 render"); }

    // T05: render with multiple vars
    string:r2 = raw template_render("{{name}} v{{version}}");
    int32:cmp5 = aria_libc_string_strcmp(r2, "Aria v0.2.6");
    if (cmp5 == 0i32) { drop println("[PASS] T05 render multi"); }
    if (cmp5 != 0i32) { drop println("[FAIL] T05 render multi"); }

    // T06: remove
    int32:rm = raw template_remove("version");
    int32:cnt2 = raw template_count();
    if (cnt2 == 1i32) { drop println("[PASS] T06 remove"); }
    if (cnt2 != 1i32) { drop println("[FAIL] T06 remove"); }

    // T07: clear
    drop template_clear();
    int32:cnt3 = raw template_count();
    if (cnt3 == 0i32) { drop println("[PASS] T07 clear"); }
    if (cnt3 != 0i32) { drop println("[FAIL] T07 clear"); }

    exit 0;
};
