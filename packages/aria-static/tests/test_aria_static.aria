// test_aria_static.aria — Tests for static file serving

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_static_shim" {
    func:aria_static_set_root      = void(string:root);
    func:aria_static_get_root      = string();
    func:aria_static_set_index     = void(string:filename);
    func:aria_static_resolve       = int32(string:url_path);
    func:aria_static_mime_type     = string();
    func:aria_static_read          = int32();
    func:aria_static_content       = string();
    func:aria_static_length        = int32();
    func:aria_static_resolved_path = string();
    func:aria_static_detect_mime   = string(string:path);
    func:aria_static_error         = string();
    func:aria_static_reset         = void();
    func:aria_static_assert_str_eq  = void(string:label, string:expected, string:actual);
    func:aria_static_assert_int_eq  = void(string:label, int32:expected, int32:actual);
    func:aria_static_assert_contains = void(string:label, string:expected, string:actual);
    func:aria_static_test_summary   = void();
}

func:main = int32() {
    // ── Test 1: MIME type detection ──
    string:m1 = aria_static_detect_mime("style.css");
    aria_static_assert_str_eq("mime css", "text/css", m1);

    string:m2 = aria_static_detect_mime("app.js");
    aria_static_assert_str_eq("mime js", "application/javascript", m2);

    string:m3 = aria_static_detect_mime("data.json");
    aria_static_assert_str_eq("mime json", "application/json", m3);

    string:m4 = aria_static_detect_mime("photo.png");
    aria_static_assert_str_eq("mime png", "image/png", m4);

    string:m5 = aria_static_detect_mime("page.html");
    aria_static_assert_str_eq("mime html", "text/html", m5);

    string:m6 = aria_static_detect_mime("file.xyz");
    aria_static_assert_str_eq("mime unknown", "application/octet-stream", m6);

    string:m7 = aria_static_detect_mime("image.svg");
    aria_static_assert_str_eq("mime svg", "image/svg+xml", m7);

    string:m8 = aria_static_detect_mime("module.wasm");
    aria_static_assert_str_eq("mime wasm", "application/wasm", m8);

    // ── Test 2: Resolve and read a file ──
    aria_static_reset();
    aria_static_set_root("./public");

    int32:r1 = aria_static_resolve("/index.html");
    aria_static_assert_int_eq("resolve index", 1i32, r1);

    string:mime1 = aria_static_mime_type();
    aria_static_assert_str_eq("index mime", "text/html", mime1);

    int32:size1 = aria_static_read();
    aria_static_assert_int_eq("index read ok", 32i32, size1);

    string:content1 = aria_static_content();
    aria_static_assert_contains("index content", "<html>", content1);

    // ── Test 3: Resolve CSS file ──
    int32:r2 = aria_static_resolve("/css/style.css");
    aria_static_assert_int_eq("resolve css", 1i32, r2);

    string:mime2 = aria_static_mime_type();
    aria_static_assert_str_eq("css mime", "text/css", mime2);

    int32:size2 = aria_static_read();
    string:content2 = aria_static_content();
    aria_static_assert_contains("css content", "color: red", content2);

    // ── Test 4: Resolve JSON file ──
    int32:r3 = aria_static_resolve("/data.json");
    aria_static_assert_int_eq("resolve json", 1i32, r3);

    string:mime3 = aria_static_mime_type();
    aria_static_assert_str_eq("json mime", "application/json", mime3);

    // ── Test 5: Path traversal blocked ──
    int32:r4 = aria_static_resolve("/../../../etc/passwd");
    aria_static_assert_int_eq("traversal blocked", 0i32, r4);

    string:err1 = aria_static_error();
    aria_static_assert_contains("traversal error", "traversal", err1);

    // ── Test 6: Non-existent file ──
    int32:r5 = aria_static_resolve("/nonexistent.html");
    aria_static_assert_int_eq("missing file", 0i32, r5);

    // ── Test 7: Set root directory ──
    aria_static_set_root("/tmp");
    string:root = aria_static_get_root();
    aria_static_assert_str_eq("root changed", "/tmp", root);

    // ── Test 8: Reset restores defaults ──
    aria_static_reset();
    string:root2 = aria_static_get_root();
    aria_static_assert_str_eq("reset root", "./public", root2);

    aria_static_test_summary();
    exit 0;
};
