pub func:static_read = int32() {
    drop _s_init();
    int64:meta = aria_libc_mem_get_global(14i32);
    int64:rn = aria_libc_mem_read_i64(meta, 528i64);
    if (rn == 0i64) {
        drop _s_set_error("No file resolved");
        pass 0i32 - 1i32;
    }

    string:rpath = aria_libc_string_from_buf(meta, 536i64, rn);
    int64:fh = aria_libc_io_fopen(rpath, "rb");
    if (fh == 0i64) {
        drop _s_set_error("Cannot open file");
        pass 0i32 - 1i32;
    }

    int32:_sk1 = aria_libc_io_fseek(fh, 0i64, 2i32);
    int64:sz = aria_libc_io_ftell(fh);
    int32:_sk2 = aria_libc_io_fseek(fh, 0i64, 0i32);

    if (sz < 0i64) { sz = 0i64; }
    if (sz > 1048576i64) {
        int32:_fc2 = aria_libc_io_fclose(fh);
        drop _s_set_error("File too large");
        pass 0i32 - 1i32;
    }

    // Free old buffer
    int64:old = aria_libc_mem_read_i64(meta, 5288i64);
    if (old != 0i64) { aria_libc_mem_free(old); }

    // Allocate and read
    int64:buf = aria_libc_mem_malloc(sz + 1i64);
    aria_libc_mem_zero(buf, sz + 1i64);
    int64:nr = aria_libc_io_fread(buf, 1i64, sz, fh);
    int32:_fc3 = aria_libc_io_fclose(fh);

    aria_libc_mem_write_byte(buf, nr, 0i32);
    aria_libc_mem_write_i64(meta, 5288i64, buf);
    aria_libc_mem_write_i64(meta, 5296i64, nr);

    pass @cast<int32>(nr);
};

