pub func:static_resolve = int32(string:url_path) {
    drop _s_init();
    int64:meta = aria_libc_mem_get_global(14i32);

    // Path traversal check
    int64:dd = aria_libc_string_strstr(url_path, "..");
    if (dd >= 0i64) {
        drop _s_set_error("Path traversal detected");
        pass 0i32;
    }

    // Build path: root + url_path
    int64:rlen = aria_libc_mem_read_i64(meta, 0i64);
    string:root_s = aria_libc_string_from_buf(meta, 8i64, rlen);
    aria_libc_string_copy_to_buf(meta, 536i64, root_s, 0i64, rlen);

    int64:pos = rlen;
    int32:fb = aria_libc_string_byte_at(url_path, 0i64);
    if (fb != 47i32) {
        aria_libc_string_copy_to_buf(meta, 536i64 + pos, "/", 0i64, 1i64);
        pos = pos + 1i64;
    }

    int64:ulen = aria_libc_string_strlen(url_path);
    aria_libc_string_copy_to_buf(meta, 536i64 + pos, url_path, 0i64, ulen);
    pos = pos + ulen;
    aria_libc_mem_write_byte(meta, 536i64 + pos, 0i32);
    aria_libc_mem_write_i64(meta, 528i64, pos);

    // Try to open
    string:full = aria_libc_string_from_buf(meta, 536i64, pos);
    int64:fh = aria_libc_io_fopen(full, "r");

    if (fh == 0i64) {
        // Try with index appended
        aria_libc_string_copy_to_buf(meta, 536i64 + pos, "/", 0i64, 1i64);
        int64:ilen = aria_libc_mem_read_i64(meta, 264i64);
        string:idx_s = aria_libc_string_from_buf(meta, 272i64, ilen);
        aria_libc_string_copy_to_buf(meta, 536i64 + pos + 1i64, idx_s, 0i64, ilen);
        int64:pos2 = pos + 1i64 + ilen;
        aria_libc_mem_write_byte(meta, 536i64 + pos2, 0i32);
        string:full2 = aria_libc_string_from_buf(meta, 536i64, pos2);
        fh = aria_libc_io_fopen(full2, "r");
        if (fh == 0i64) {
            drop _s_set_error("File not found");
            pass 0i32;
        }
        pos = pos2;
        aria_libc_mem_write_i64(meta, 528i64, pos);
    }

    int32:_fc1 = aria_libc_io_fclose(fh);

    // Detect MIME from url_path (safe — not from g_buf)
    string:m = raw _s_mime_str(url_path);
    drop _s_store_mime(m);

    pass 1i32;
};

