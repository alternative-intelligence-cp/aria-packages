// test_aria_test.aria — Self-test for the aria-test framework (pure Aria)

use "../src/testing.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    drop test_begin("aria-test self-test");

    // ── basic boolean assertion ──────────────────────────────────────
    drop test_assert("true is true", 1i32);

    // ── int32 equality ──────────────────────────────────────────────
    drop test_assert_eq_i32("1 + 1 = 2", 1i32 + 1i32, 2i32);

    // ── int64 equality ──────────────────────────────────────────────
    drop test_assert_eq_i64("100 + 200 = 300", 100i64 + 200i64, 300i64);

    // ── string equality ─────────────────────────────────────────────
    drop test_assert_eq_str("hello == hello", "hello", "hello");

    // ── float near-equal ────────────────────────────────────────────
    drop test_assert_near_f64("3.14 ~ pi", 3.14f64, 3.14159f64, 0.01f64);

    // ── not-empty ───────────────────────────────────────────────────
    drop test_assert_not_empty("non-empty string", "content");

    // ── skip ────────────────────────────────────────────────────────
    drop test_skip("skipped test");

    // ── gt_i32 ──────────────────────────────────────────────────────
    drop test_assert_gt_i32("10 > 5", 10i32, 5i32);

    // ── gt_i64 ──────────────────────────────────────────────────────
    drop test_assert_gt_i64("1000 > 500", 1000i64, 500i64);

    // ── ne_i32 ──────────────────────────────────────────────────────
    drop test_assert_ne_i32("1 != 2", 1i32, 2i32);

    // ── verify counts ───────────────────────────────────────────────
    int64:p = raw test_passed_count();
    int64:f = raw test_failed_count();
    int64:s = raw test_skipped_count();
    int64:t = raw test_total_count();

    // 9 passed, 0 failed, 1 skipped = 10 total
    drop test_assert("passed count = 9", @cast<int32>(p == 9i64));
    drop test_assert("failed count = 0", @cast<int32>(f == 0i64));
    drop test_assert("skipped count = 1", @cast<int32>(s == 1i64));
    drop test_assert("total count = 10", @cast<int32>(t == 10i64));

    int32:result = raw test_end();
    exit result;
};
