pub func:cuda_blas_sgemm_ex = int32(int32:trans_a, int32:trans_b, int32:M, int32:N, int32:K, flt64:alpha, int64:d_A, int32:lda, int64:d_B, int32:ldb, flt64:beta, int64:d_C, int32:ldc) {
    pass(aria_cuda_blas_sgemm_ex(trans_a, trans_b, M, N, K, alpha, d_A, lda, d_B, ldb, beta, d_C, ldc));
