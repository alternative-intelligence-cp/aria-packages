// test_aria_looping.aria — Looping model test suite (pure Aria)
//
// Compile:
//   ariac test_aria_looping.aria -o test_looping \
//     -L../../aria-libc/shim -laria_libc_mem -laria_libc_string -laria_libc_math -lm
// Run:
//   LD_LIBRARY_PATH=../../aria-libc/shim ./test_looping

use "../src/aria_looping.aria".*;

extern "aria_libc_string" {
    func:aria_libc_string_from_i64 = string(int64:v);
}

func:failsafe = int32(tbb32:err) { exit 1; };

func:s = string(int64:v) {
    pass aria_libc_string_from_i64(v);
};

func:main = int32() {
    int32:passed = 0i32;
    int32:total  = 0i32;

    println("=== aria-looping test suite ===");
    println("");

    drop looping_set_seed(42i32);

    // T01: Create model (d_model=16, n_heads=4, ffn=64, iters=6, vocab=64, seq=16)
    total += 1i32;
    int64:model = raw looping_create(16i32, 4i32, 64i32, 6i32, 64i32, 16i32);
    print("T01 create: id=");
    println(raw s(model));
    if (model >= 0i64) { println("  PASS"); passed += 1i32; }

    // T02: Metadata
    total += 1i32;
    int32:dm = raw looping_d_model(model);
    int32:nh = raw looping_n_heads(model);
    int32:ff = raw looping_ffn_dim(model);
    int32:mi = raw looping_max_iters(model);
    int32:vs = raw looping_vocab_size(model);
    print("T02 meta: dm=");
    print(raw s(@cast<int64>(dm)));
    print(" nh=");
    print(raw s(@cast<int64>(nh)));
    print(" ff=");
    print(raw s(@cast<int64>(ff)));
    print(" mi=");
    print(raw s(@cast<int64>(mi)));
    print(" vs=");
    println(raw s(@cast<int64>(vs)));
    if (dm == 16i32) {
        if (nh == 4i32) {
            if (mi == 6i32) {
                println("  PASS");
                passed += 1i32;
            }
        }
    }

    // T03: Param count
    total += 1i32;
    int64:params = raw looping_param_count(model);
    print("T03 params: ");
    println(raw s(params));
    if (params > 0i64) { println("  PASS"); passed += 1i32; }

    // T04: Forward (default max_iters)
    total += 1i32;
    int64:inp = raw looping_scratch_create(4i32, 1i32);
    drop looping_scratch_set(inp, 0i32, 1.0);
    drop looping_scratch_set(inp, 1i32, 5.0);
    drop looping_scratch_set(inp, 2i32, 10.0);
    drop looping_scratch_set(inp, 3i32, 3.0);
    int64:logits = raw looping_forward(model, inp);
    print("T04 forward: logits=");
    println(raw s(logits));
    if (logits >= 0i64) {
        int32:lr = raw looping_scratch_rows(logits);
        int32:lc = raw looping_scratch_cols(logits);
        print("  shape: [");
        print(raw s(@cast<int64>(lr)));
        print(" x ");
        print(raw s(@cast<int64>(lc)));
        println("]");
        int32:used = raw looping_last_iters_used(model);
        print("  iters: ");
        println(raw s(@cast<int64>(used)));
        if (lr == 4i32) {
            if (lc == 64i32) {
                if (used == 6i32) {
                    println("  PASS");
                    passed += 1i32;
                }
            }
        }
    }

    // T05: Forward with specific iteration count
    total += 1i32;
    int64:logits2 = raw looping_forward_n(model, inp, 2i32);
    print("T05 forward_n(2): ");
    if (logits2 >= 0i64) {
        int32:used2 = raw looping_last_iters_used(model);
        print("iters=");
        println(raw s(@cast<int64>(used2)));
        if (used2 == 2i32) { println("  PASS"); passed += 1i32; }
        drop looping_scratch_destroy(logits2);
    }

    // T06: Argmax
    total += 1i32;
    int32:pred0 = raw looping_argmax(logits, 0i32);
    int32:pred3 = raw looping_argmax(logits, 3i32);
    print("T06 argmax: pos0=");
    print(raw s(@cast<int64>(pred0)));
    print(" pos3=");
    println(raw s(@cast<int64>(pred3)));
    if (pred0 >= 0i32) {
        if (pred0 < 64i32) { println("  PASS"); passed += 1i32; }
    }

    // T07: Softmax
    total += 1i32;
    drop looping_softmax_row(logits, 0i32);
    flt64:prob_sum = 0.0;
    loop(0i64, 64i64, 1i64) {
        flt64:pv = raw looping_scratch_get(logits, @cast<int32>($));
        prob_sum = prob_sum + pv;
    }
    print("T07 softmax sum*1000=");
    println(raw s(@cast<int64>(prob_sum * 1000.0)));
    if (prob_sum > 0.99) {
        if (prob_sum < 1.01) { println("  PASS"); passed += 1i32; }
    }

    // T08: Different iteration counts produce valid outputs
    total += 1i32;
    int64:lo1 = raw looping_forward_n(model, inp, 1i32);
    int64:lo6 = raw looping_forward_n(model, inp, 6i32);
    if (lo1 >= 0i64) {
        if (lo6 >= 0i64) {
            int32:p1 = raw looping_argmax(lo1, 0i32);
            int32:p6 = raw looping_argmax(lo6, 0i32);
            print("T08 1-iter=");
            print(raw s(@cast<int64>(p1)));
            print(" 6-iter=");
            println(raw s(@cast<int64>(p6)));
            if (p1 >= 0i32) {
                if (p6 >= 0i32) { println("  PASS"); passed += 1i32; }
            }
            drop looping_scratch_destroy(lo6);
        }
        drop looping_scratch_destroy(lo1);
    }

    // T09: Convergence threshold
    total += 1i32;
    drop looping_set_threshold(model, 0.001);
    int64:logits_ct = raw looping_forward(model, inp);
    if (logits_ct >= 0i64) {
        int32:used_ct = raw looping_last_iters_used(model);
        print("T09 convergence iters=");
        println(raw s(@cast<int64>(used_ct)));
        if (used_ct >= 1i32) {
            if (used_ct <= 6i32) { println("  PASS"); passed += 1i32; }
        }
        drop looping_scratch_destroy(logits_ct);
    }
    drop looping_set_threshold(model, 0.0);

    // T10: Longer sequence (len=12)
    total += 1i32;
    int64:inp3 = raw looping_scratch_create(12i32, 1i32);
    loop(0i64, 12i64, 1i64) {
        drop looping_scratch_set(inp3, @cast<int32>($), @cast<flt64>($) * 4.0);
    }
    int64:logits3 = raw looping_forward(model, inp3);
    print("T10 seq=12: ");
    if (logits3 >= 0i64) {
        int32:lr3 = raw looping_scratch_rows(logits3);
        int32:lc3 = raw looping_scratch_cols(logits3);
        print("[");
        print(raw s(@cast<int64>(lr3)));
        print(" x ");
        print(raw s(@cast<int64>(lc3)));
        println("]");
        if (lr3 == 12i32) {
            if (lc3 == 64i32) { println("  PASS"); passed += 1i32; }
        }
        drop looping_scratch_destroy(logits3);
    }
    drop looping_scratch_destroy(inp3);

    // Cleanup
    drop looping_scratch_destroy(logits);
    drop looping_scratch_destroy(inp);
    drop looping_destroy(model);

    println("");
    print("=== Results: ");
    print(raw s(@cast<int64>(passed)));
    print("/");
    print(raw s(@cast<int64>(total)));
    println(" passed ===");
    if (passed == total) { println("ALL TESTS PASSED"); exit 0; }
    exit 1;
};
