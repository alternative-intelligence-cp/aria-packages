// test_aria_log.aria — Log module tests (7 tests)

use "../src/aria_log.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // T01: init
    drop log_init();
    drop println("[PASS] T01 log_init");

    // T02: default level is INFO (2)
    int32:lvl = raw log_get_level();
    if (lvl == 2i32) { drop println("[PASS] T02 default level=INFO"); }
    if (lvl != 2i32) { drop println("[FAIL] T02 default level=INFO"); }

    // T03: set level to TRACE (0)
    drop log_set_level(0i32);
    int32:lvl2 = raw log_get_level();
    if (lvl2 == 0i32) { drop println("[PASS] T03 set level=TRACE"); }
    if (lvl2 != 0i32) { drop println("[FAIL] T03 set level=TRACE"); }

    // T04: set level to ERROR (4)
    drop log_set_level(4i32);
    int32:lvl3 = raw log_get_level();
    if (lvl3 == 4i32) { drop println("[PASS] T04 set level=ERROR"); }
    if (lvl3 != 4i32) { drop println("[FAIL] T04 set level=ERROR"); }

    // T05: set level to FATAL (5)
    drop log_set_level(5i32);
    int32:lvl4 = raw log_get_level();
    if (lvl4 == 5i32) { drop println("[PASS] T05 set level=FATAL"); }
    if (lvl4 != 5i32) { drop println("[FAIL] T05 set level=FATAL"); }

    // T06: log_count starts at 0 after init
    drop log_init();
    int64:cnt = raw log_count();
    if (cnt == 0i64) { drop println("[PASS] T06 count=0 after init"); }
    if (cnt != 0i64) { drop println("[FAIL] T06 count=0 after init"); }

    // T07: log_info increments count (send to stdout to capture)
    drop log_to_stdout();
    drop log_set_level(0i32);
    drop log_show_timestamp(0i32);
    drop log_info("test message");
    int64:cnt2 = raw log_count();
    if (cnt2 == 1i64) { drop println("[PASS] T07 count after log_info"); }
    if (cnt2 != 1i64) { drop println("[FAIL] T07 count after log_info"); }

    exit 0;
};
