// test_aria_datetime.aria — Time basics (4 tests)

use "../src/aria_datetime.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // T01: now > 0
    int64:now = raw dt_now();
    if (now > 0i64) { drop println("[PASS] T01 now > 0"); }
    if (now <= 0i64) { drop println("[FAIL] T01 now > 0"); }

    // T02: now_ms > 0
    int64:ms = raw dt_now_ms();
    if (ms > 0i64) { drop println("[PASS] T02 now_ms > 0"); }
    if (ms <= 0i64) { drop println("[FAIL] T02 now_ms > 0"); }

    // T03: now_us > now_ms
    int64:us = raw dt_now_us();
    if (us > ms) { drop println("[PASS] T03 now_us > now_ms"); }
    if (us <= ms) { drop println("[FAIL] T03 now_us > now_ms"); }

    // T04: monotonic > 0
    int64:mono = raw dt_monotonic_ms();
    if (mono > 0i64) { drop println("[PASS] T04 monotonic > 0"); }
    if (mono <= 0i64) { drop println("[FAIL] T04 monotonic > 0"); }

    exit 0;
};
