// test_aria_semver.aria — SemVer tests (8 tests)

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_semver_shim" {
    func:aria_semver_parse          = int32(string:version);
    func:aria_semver_get_major      = int32();
    func:aria_semver_get_minor      = int32();
    func:aria_semver_get_patch      = int32();
    func:aria_semver_get_prerelease = string();
    func:aria_semver_get_build      = string();
    func:aria_semver_to_string      = string();
    func:aria_semver_compare        = int32(string:a, string:b);
    func:aria_semver_satisfies      = int32(string:version, string:constraint);
    func:aria_semver_bump_major     = string(string:version);
    func:aria_semver_bump_minor     = string(string:version);
    func:aria_semver_bump_patch     = string(string:version);
}

func:main = int32() {
    // T01: parse
    int32:r1 = aria_semver_parse("1.2.3");
    if (r1 == 1i32) { drop println("[PASS] T01 parse"); }
    if (r1 != 1i32) { drop println("[FAIL] T01 parse"); }

    // T02: major
    int32:maj = aria_semver_get_major();
    if (maj == 1i32) { drop println("[PASS] T02 major"); }
    if (maj != 1i32) { drop println("[FAIL] T02 major"); }

    // T03: minor
    int32:min = aria_semver_get_minor();
    if (min == 2i32) { drop println("[PASS] T03 minor"); }
    if (min != 2i32) { drop println("[FAIL] T03 minor"); }

    // T04: patch
    int32:pat = aria_semver_get_patch();
    if (pat == 3i32) { drop println("[PASS] T04 patch"); }
    if (pat != 3i32) { drop println("[FAIL] T04 patch"); }

    // T05: compare equal
    int32:c1 = aria_semver_compare("1.0.0", "1.0.0");
    if (c1 == 0i32) { drop println("[PASS] T05 compare equal"); }
    if (c1 != 0i32) { drop println("[FAIL] T05 compare equal"); }

    // T06: compare less
    int32:c2 = aria_semver_compare("1.0.0", "2.0.0");
    if (c2 == -1i32) { drop println("[PASS] T06 compare less"); }
    if (c2 != -1i32) { drop println("[FAIL] T06 compare less"); }

    // T07: compare greater
    int32:c3 = aria_semver_compare("2.1.0", "1.9.0");
    if (c3 == 1i32) { drop println("[PASS] T07 compare greater"); }
    if (c3 != 1i32) { drop println("[FAIL] T07 compare greater"); }

    // T08: satisfies
    int32:s1 = aria_semver_satisfies("1.2.3", ">=1.0.0");
    if (s1 == 1i32) { drop println("[PASS] T08 satisfies"); }
    if (s1 != 1i32) { drop println("[FAIL] T08 satisfies"); }

    exit 0;
};
