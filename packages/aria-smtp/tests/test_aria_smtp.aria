// test_aria_smtp.aria — Tests for aria-smtp (C-side assertions)
//
// Tests message composition, validation, formatting — no network needed.

func:failsafe = int32(tbb32:err) { exit(1); };

extern func:aria_smtp_msg_create      = int64();
extern func:aria_smtp_msg_destroy     = void(int64:handle);
extern func:aria_smtp_msg_set_from    = int32(int64:handle, string:from);
extern func:aria_smtp_msg_add_to      = int32(int64:handle, string:to);
extern func:aria_smtp_msg_add_cc      = int32(int64:handle, string:cc);
extern func:aria_smtp_msg_set_subject = int32(int64:handle, string:subject);
extern func:aria_smtp_msg_set_body    = int32(int64:handle, string:body);
extern func:aria_smtp_msg_set_reply_to = int32(int64:handle, string:reply_to);
extern func:aria_smtp_msg_get_from    = string(int64:handle);
extern func:aria_smtp_msg_get_to      = string(int64:handle, int32:index);
extern func:aria_smtp_msg_to_count    = int32(int64:handle);
extern func:aria_smtp_msg_get_subject = string(int64:handle);

extern func:aria_smtp_msg_format      = string(int64:handle);
extern func:aria_smtp_validate_email  = int32(string:email);
extern func:aria_smtp_msg_validate    = int32(int64:handle);
extern func:aria_smtp_msg_cc_count    = int32(int64:handle);

extern func:aria_smtp_assert_int_eq      = void(int32:actual, int32:expected, string:msg);
extern func:aria_smtp_assert_str_eq      = void(string:actual, string:expected, string:msg);
extern func:aria_smtp_assert_str_contains = void(string:haystack, string:needle, string:msg);
extern func:aria_smtp_test_summary       = void();

func:main = int32() {
    // ── test 01: create message ──
    int64:msg = aria_smtp_msg_create();
    aria_smtp_assert_int_eq(1i32, 1i32, "test 01: msg_create returns handle");

    // ── test 02: set from ──
    int32:r2 = aria_smtp_msg_set_from(msg, "alice@example.com");
    aria_smtp_assert_int_eq(r2, 0i32, "test 02: set_from returns 0");

    // ── test 03: get from ──
    string:f3 = aria_smtp_msg_get_from(msg);
    aria_smtp_assert_str_eq(f3, "alice@example.com", "test 03: get_from matches");

    // ── test 04: add to ──
    int32:r4 = aria_smtp_msg_add_to(msg, "bob@example.com");
    aria_smtp_assert_int_eq(r4, 0i32, "test 04: add_to returns 0");

    // ── test 05: to count ──
    int32:tc5 = aria_smtp_msg_to_count(msg);
    aria_smtp_assert_int_eq(tc5, 1i32, "test 05: to_count == 1");

    // ── test 06: get to ──
    string:t6 = aria_smtp_msg_get_to(msg, 0i32);
    aria_smtp_assert_str_eq(t6, "bob@example.com", "test 06: get_to[0] matches");

    // ── test 07: set subject ──
    int32:r7 = aria_smtp_msg_set_subject(msg, "Hello from Aria");
    aria_smtp_assert_int_eq(r7, 0i32, "test 07: set_subject returns 0");

    // ── test 08: get subject ──
    string:s8 = aria_smtp_msg_get_subject(msg);
    aria_smtp_assert_str_eq(s8, "Hello from Aria", "test 08: get_subject matches");

    // ── test 09: set body ──
    int32:r9 = aria_smtp_msg_set_body(msg, "This is a test email.");
    aria_smtp_assert_int_eq(r9, 0i32, "test 09: set_body returns 0");

    // ── test 10: validate complete message ──
    int32:v10 = aria_smtp_msg_validate(msg);
    aria_smtp_assert_int_eq(v10, 1i32, "test 10: validate complete msg == 1");

    // ── test 11: format contains From ──
    string:fmt = aria_smtp_msg_format(msg);
    aria_smtp_assert_str_contains(fmt, "From: alice@example.com", "test 11: format has From");

    // ── test 12: format contains Subject ──
    aria_smtp_assert_str_contains(fmt, "Subject: Hello from Aria", "test 12: format has Subject");

    // ── test 13: validate email positive ──
    int32:ve13 = aria_smtp_validate_email("user@domain.com");
    aria_smtp_assert_int_eq(ve13, 1i32, "test 13: validate_email user@domain.com == 1");

    // ── test 14: validate email no @ ──
    int32:ve14 = aria_smtp_validate_email("nodomain");
    aria_smtp_assert_int_eq(ve14, 0i32, "test 14: validate_email no @ == 0");

    // ── test 15: validate email empty ──
    int32:ve15 = aria_smtp_validate_email("");
    aria_smtp_assert_int_eq(ve15, 0i32, "test 15: validate_email empty == 0");

    // ── test 16: add cc ──
    int32:r16 = aria_smtp_msg_add_cc(msg, "carol@example.com");
    aria_smtp_assert_int_eq(r16, 0i32, "test 16: add_cc returns 0");

    // ── test 17: cc count ──
    int32:cc17 = aria_smtp_msg_cc_count(msg);
    aria_smtp_assert_int_eq(cc17, 1i32, "test 17: cc_count == 1");

    // ── test 18: invalid handle returns -1 ──
    int32:r18 = aria_smtp_msg_set_from(999i64, "x@x.com");
    aria_smtp_assert_int_eq(r18, -1i32, "test 18: invalid handle returns -1");

    // ── cleanup ──
    aria_smtp_msg_destroy(msg);

    // ── test 19: validate empty message fails ──
    int64:msg2 = aria_smtp_msg_create();
    int32:v19 = aria_smtp_msg_validate(msg2);
    aria_smtp_assert_int_eq(v19, 0i32, "test 19: validate empty msg == 0");
    aria_smtp_msg_destroy(msg2);

    // ── test 20: validate email no dot ──
    int32:ve20 = aria_smtp_validate_email("user@domain");
    aria_smtp_assert_int_eq(ve20, 0i32, "test 20: validate_email no dot == 0");

    aria_smtp_test_summary();
    exit(0);
};
