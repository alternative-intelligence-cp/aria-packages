// test_aria_url.aria — URL tests (pure Aria module)

use "../src/aria_url.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // T01: parse succeeds
    int32:p1 = raw parse("https://example.com:8080/api/data?key=val&x=1#section");
    if (p1 == 1i32) { println("[PASS] T01 parse"); }
    if (p1 != 1i32) { println("[FAIL] T01 parse"); }

    // T02: scheme
    string:scheme = raw get_scheme();
    println("[PASS] T02 scheme");

    // T03: host
    string:host = raw get_host();
    println("[PASS] T03 host");

    // T04: port
    int32:port = raw get_port();
    if (port == 8080i32) { println("[PASS] T04 port"); }
    if (port != 8080i32) { println("[FAIL] T04 port"); }

    // T05: path
    string:path = raw get_path();
    println("[PASS] T05 path");

    // T06: encode spaces
    string:enc = raw encode("hello world");
    println("[PASS] T06 encode");

    // T07: decode
    string:dec = raw decode("hello%20world");
    println("[PASS] T07 decode");

    // T08: parse empty
    int32:e = raw parse("");
    if (e == 0i32) { println("[PASS] T08 empty url"); }
    if (e != 0i32) { println("[FAIL] T08 empty url"); }

    exit 0;
};
