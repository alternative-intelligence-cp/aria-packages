// test_aria_ini.aria — INI parser tests (15 tests)

use "../src/aria_ini.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // T01: parse simple INI
    int32:secs = raw ini_parse("[server]\nhost = localhost\nport = 8080\n\n[database]\nname = mydb\n");
    if (secs == 2i32) { drop println("[PASS] T01 parsed 2 sections"); }
    if (secs != 2i32) { drop println("[FAIL] T01 parsed 2 sections"); }

    // T02: num_sections
    int32:ns = raw ini_num_sections();
    if (ns == 2i32) { drop println("[PASS] T02 num_sections == 2"); }
    if (ns != 2i32) { drop println("[FAIL] T02 num_sections == 2"); }

    // T03: get server host
    string:host = raw ini_get("server", "host");
    int32:c3 = aria_libc_string_strcmp(host, "localhost");
    if (c3 == 0i32) { drop println("[PASS] T03 server.host = localhost"); }
    if (c3 != 0i32) { drop println("[FAIL] T03 server.host = localhost"); }

    // T04: get server port
    string:port = raw ini_get("server", "port");
    int32:c4 = aria_libc_string_strcmp(port, "8080");
    if (c4 == 0i32) { drop println("[PASS] T04 server.port = 8080"); }
    if (c4 != 0i32) { drop println("[FAIL] T04 server.port = 8080"); }

    // T05: get database name
    string:dbname = raw ini_get("database", "name");
    int32:c5 = aria_libc_string_strcmp(dbname, "mydb");
    if (c5 == 0i32) { drop println("[PASS] T05 database.name = mydb"); }
    if (c5 != 0i32) { drop println("[FAIL] T05 database.name = mydb"); }

    // T06: has_key positive
    int32:hk = raw ini_has_key("server", "host");
    if (hk == 1i32) { drop println("[PASS] T06 has_key server.host"); }
    if (hk != 1i32) { drop println("[FAIL] T06 has_key server.host"); }

    // T07: has_key negative
    int32:hk2 = raw ini_has_key("server", "missing");
    if (hk2 == 0i32) { drop println("[PASS] T07 has_key server.missing == 0"); }
    if (hk2 != 0i32) { drop println("[FAIL] T07 has_key server.missing == 0"); }

    // T08: comments ignored
    int32:cs = raw ini_parse("[app]\n; this is a comment\nname = test\n# another comment\nmode = dev\n");
    string:an = raw ini_get("app", "name");
    int32:c8 = aria_libc_string_strcmp(an, "test");
    if (c8 == 0i32) { drop println("[PASS] T08 comments ignored"); }
    if (c8 != 0i32) { drop println("[FAIL] T08 comments ignored"); }

    // T09: mode after comments
    string:am = raw ini_get("app", "mode");
    int32:c9 = aria_libc_string_strcmp(am, "dev");
    if (c9 == 0i32) { drop println("[PASS] T09 mode = dev"); }
    if (c9 != 0i32) { drop println("[FAIL] T09 mode = dev"); }

    // T10: whitespace trimming
    int32:ws = raw ini_parse("[fmt]\n  key1  =  value1  \nkey2=value2\n");
    string:v10 = raw ini_get("fmt", "key1");
    int32:c10 = aria_libc_string_strcmp(v10, "value1");
    if (c10 == 0i32) { drop println("[PASS] T10 whitespace trimmed"); }
    if (c10 != 0i32) { drop println("[FAIL] T10 whitespace trimmed"); }

    // T11: no-space equals
    string:v11 = raw ini_get("fmt", "key2");
    int32:c11 = aria_libc_string_strcmp(v11, "value2");
    if (c11 == 0i32) { drop println("[PASS] T11 key2=value2"); }
    if (c11 != 0i32) { drop println("[FAIL] T11 key2=value2"); }

    // T12: empty input
    int32:ei = raw ini_parse("");
    if (ei == 0i32) { drop println("[PASS] T12 empty input"); }
    if (ei != 0i32) { drop println("[FAIL] T12 empty input"); }

    // T13: global keys (no section header)
    int32:gk = raw ini_parse("key = globalval\n[sec]\nk = v\n");
    string:gv = raw ini_get("", "key");
    int32:c13 = aria_libc_string_strcmp(gv, "globalval");
    if (c13 == 0i32) { drop println("[PASS] T13 global key"); }
    if (c13 != 0i32) { drop println("[FAIL] T13 global key"); }

    // T14: section count with global
    int32:gns = raw ini_num_sections();
    if (gns == 2i32) { drop println("[PASS] T14 2 sections with global"); }
    if (gns != 2i32) { drop println("[FAIL] T14 2 sections with global"); }

    // T15: multiple keys in section
    int32:mk = raw ini_parse("[multi]\na = 1\nb = 2\nc = 3\nd = 4\ne = 5\n");
    int32:mks = raw ini_has_key("multi", "e");
    if (mks == 1i32) { drop println("[PASS] T15 5 keys, key e exists"); }
    if (mks != 1i32) { drop println("[FAIL] T15 5 keys, key e exists"); }

    drop ini_cleanup();
    exit 0;
};
