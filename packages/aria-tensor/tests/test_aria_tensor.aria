// test_aria_tensor.aria — tensor library test suite
//
// Compile:
//   ariac test_aria_tensor.aria -o test_tensor -L../shim -laria_tensor_shim -lm
// Run:
//   LD_LIBRARY_PATH=../shim ./test_tensor

use "print_utils.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_tensor_shim" {
    func:aria_tensor_last_error    = string();
    func:aria_tensor_create_1d     = int64(int32:n);
    func:aria_tensor_create_2d     = int64(int32:rows, int32:cols);
    func:aria_tensor_destroy       = void(int64:id);
    func:aria_tensor_clone         = int64(int64:id);
    func:aria_tensor_ndim          = int32(int64:id);
    func:aria_tensor_size          = int32(int64:id);
    func:aria_tensor_shape_at      = int32(int64:id, int32:dim);
    func:aria_tensor_set_1d        = void(int64:id, int32:i, flt64:val);
    func:aria_tensor_get_1d        = flt64(int64:id, int32:i);
    func:aria_tensor_set_2d        = void(int64:id, int32:r, int32:c, flt64:val);
    func:aria_tensor_get_2d        = flt64(int64:id, int32:r, int32:c);
    func:aria_tensor_fill          = void(int64:id, flt64:val);
    func:aria_tensor_fill_range    = void(int64:id, flt64:start, flt64:step);
    func:aria_tensor_reshape       = int64(int64:id, int32:d0, int32:d1, int32:d2, int32:d3);
    func:aria_tensor_transpose     = int64(int64:id);
    func:aria_tensor_add           = int64(int64:a, int64:b);
    func:aria_tensor_sub           = int64(int64:a, int64:b);
    func:aria_tensor_mul           = int64(int64:a, int64:b);
    func:aria_tensor_scale         = int64(int64:id, flt64:alpha);
    func:aria_tensor_add_bias      = int64(int64:id, int64:bias);
    func:aria_tensor_matmul        = int64(int64:a, int64:b);
    func:aria_tensor_relu          = int64(int64:id);
    func:aria_tensor_sigmoid       = int64(int64:id);
    func:aria_tensor_softmax       = int64(int64:id);
    func:aria_tensor_sum           = flt64(int64:id);
    func:aria_tensor_mean          = flt64(int64:id);
    func:aria_tensor_max_val       = flt64(int64:id);
    func:aria_tensor_min_val       = flt64(int64:id);
    func:aria_tensor_layer_norm    = int64(int64:id, flt64:eps);
    func:aria_tensor_print         = void(int64:id);
    func:aria_tensor_set_rng_seed  = void(int32:seed);
}

func:main = int32() {
    int32:passed = 0i32;
    int32:total  = 0i32;

    println("=== aria-tensor test suite ===");
    println("");

    // ── Test 1: Create 1D tensor ──
    total += 1i32;
    int64:v = aria_tensor_create_1d(5i32);
    int32:nd = aria_tensor_ndim(v);
    int32:sz = aria_tensor_size(v);
    print("Test 1 — Create 1D(5): ndim=");
    print(string_from_int(@cast<int64>(nd)));
    print(" size=");
    println(string_from_int(@cast<int64>(sz)));
    if (nd == 1i32) {
        if (sz == 5i32) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 2: Set/get 1D ──
    total += 1i32;
    aria_tensor_set_1d(v, 0i32, 10.5);
    aria_tensor_set_1d(v, 1i32, 20.5);
    aria_tensor_set_1d(v, 4i32, 50.5);
    flt64:g0 = aria_tensor_get_1d(v, 0i32);
    flt64:g4 = aria_tensor_get_1d(v, 4i32);
    print("Test 2 — Get: [0]=");
    print(string_from_int(@cast<int64>(g0)));
    print(" [4]=");
    println(string_from_int(@cast<int64>(g4)));
    if (@cast<int64>(g0) == 10i64) {
        if (@cast<int64>(g4) == 50i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 3: Create 2D, set, matmul ──
    total += 1i32;
    // A = [[1,2],[3,4]]  B = [[5,6],[7,8]]
    int64:a = aria_tensor_create_2d(2i32, 2i32);
    aria_tensor_set_2d(a, 0i32, 0i32, 1.0);
    aria_tensor_set_2d(a, 0i32, 1i32, 2.0);
    aria_tensor_set_2d(a, 1i32, 0i32, 3.0);
    aria_tensor_set_2d(a, 1i32, 1i32, 4.0);

    int64:b = aria_tensor_create_2d(2i32, 2i32);
    aria_tensor_set_2d(b, 0i32, 0i32, 5.0);
    aria_tensor_set_2d(b, 0i32, 1i32, 6.0);
    aria_tensor_set_2d(b, 1i32, 0i32, 7.0);
    aria_tensor_set_2d(b, 1i32, 1i32, 8.0);

    int64:c = aria_tensor_matmul(a, b);
    flt64:c00 = aria_tensor_get_2d(c, 0i32, 0i32);
    flt64:c01 = aria_tensor_get_2d(c, 0i32, 1i32);
    flt64:c10 = aria_tensor_get_2d(c, 1i32, 0i32);
    flt64:c11 = aria_tensor_get_2d(c, 1i32, 1i32);
    print("Test 3 — Matmul: [[");
    print(string_from_int(@cast<int64>(c00)));
    print(",");
    print(string_from_int(@cast<int64>(c01)));
    print("],[");
    print(string_from_int(@cast<int64>(c10)));
    print(",");
    print(string_from_int(@cast<int64>(c11)));
    println("]]");
    // Expected: [[19,22],[43,50]]
    if (@cast<int64>(c00) == 19i64) {
        if (@cast<int64>(c11) == 50i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 4: Transpose ──
    total += 1i32;
    int64:at = aria_tensor_transpose(a);
    flt64:t00 = aria_tensor_get_2d(at, 0i32, 0i32);
    flt64:t01 = aria_tensor_get_2d(at, 0i32, 1i32);
    flt64:t10 = aria_tensor_get_2d(at, 1i32, 0i32);
    flt64:t11 = aria_tensor_get_2d(at, 1i32, 1i32);
    print("Test 4 — Transpose: [[");
    print(string_from_int(@cast<int64>(t00)));
    print(",");
    print(string_from_int(@cast<int64>(t01)));
    print("],[");
    print(string_from_int(@cast<int64>(t10)));
    print(",");
    print(string_from_int(@cast<int64>(t11)));
    println("]]");
    // A=[[1,2],[3,4]] → A^T=[[1,3],[2,4]]
    if (@cast<int64>(t01) == 3i64) {
        if (@cast<int64>(t10) == 2i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 5: Fill + sum ──
    total += 1i32;
    int64:f = aria_tensor_create_1d(10i32);
    aria_tensor_fill(f, 3.0);
    flt64:s = aria_tensor_sum(f);
    print("Test 5 — Fill(3.0) sum of 10: ");
    println(string_from_int(@cast<int64>(s)));
    if (@cast<int64>(s) == 30i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 6: Fill range + mean ──
    total += 1i32;
    int64:fr = aria_tensor_create_1d(5i32);
    aria_tensor_fill_range(fr, 1.0, 1.0);
    // Data: [1, 2, 3, 4, 5], mean = 3.0
    flt64:m = aria_tensor_mean(fr);
    print("Test 6 — Range mean: ");
    println(string_from_int(@cast<int64>(m)));
    if (@cast<int64>(m) == 3i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 7: ReLU ──
    total += 1i32;
    int64:rv = aria_tensor_create_1d(4i32);
    aria_tensor_set_1d(rv, 0i32, 2.0);
    aria_tensor_set_1d(rv, 1i32, -1.0);
    aria_tensor_set_1d(rv, 2i32, 0.0);
    aria_tensor_set_1d(rv, 3i32, -3.0);
    int64:rv_act = aria_tensor_relu(rv);
    flt64:r0 = aria_tensor_get_1d(rv_act, 0i32);
    flt64:r1 = aria_tensor_get_1d(rv_act, 1i32);
    flt64:r3 = aria_tensor_get_1d(rv_act, 3i32);
    print("Test 7 — ReLU [2,-1,0,-3] → [");
    print(string_from_int(@cast<int64>(r0)));
    print(",");
    print(string_from_int(@cast<int64>(r1)));
    print(",");
    print(string_from_int(@cast<int64>(r3)));
    println("]");
    // Expected: [2, 0, 0, 0]
    if (@cast<int64>(r0) == 2i64) {
        if (@cast<int64>(r1) == 0i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 8: Softmax ──
    total += 1i32;
    int64:sm = aria_tensor_create_1d(3i32);
    aria_tensor_set_1d(sm, 0i32, 1.0);
    aria_tensor_set_1d(sm, 1i32, 2.0);
    aria_tensor_set_1d(sm, 2i32, 3.0);
    int64:sm_act = aria_tensor_softmax(sm);
    flt64:sm_sum = aria_tensor_sum(sm_act);
    // Multiply by 1000 and truncate — should be 1000 (or 999 due to float rounding)
    int64:sm_check = @cast<int64>(sm_sum * 1000.0);
    print("Test 8 — Softmax sum*1000: ");
    println(string_from_int(sm_check));
    // Softmax sums to 1.0 → *1000 = 1000 (or 999)
    if (sm_check >= 999i64) {
        if (sm_check <= 1000i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 9: Add + Scale ──
    total += 1i32;
    int64:x = aria_tensor_create_1d(3i32);
    aria_tensor_fill(x, 2.0);
    int64:y = aria_tensor_create_1d(3i32);
    aria_tensor_fill(y, 3.0);
    int64:xy = aria_tensor_add(x, y);
    int64:xs = aria_tensor_scale(xy, 2.0);
    flt64:xs0 = aria_tensor_get_1d(xs, 0i32);
    print("Test 9 — (2+3)*2 = ");
    println(string_from_int(@cast<int64>(xs0)));
    // (2+3)*2 = 10
    if (@cast<int64>(xs0) == 10i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 10: Layer norm ──
    total += 1i32;
    int64:ln = aria_tensor_create_2d(1i32, 4i32);
    aria_tensor_set_2d(ln, 0i32, 0i32, 1.0);
    aria_tensor_set_2d(ln, 0i32, 1i32, 2.0);
    aria_tensor_set_2d(ln, 0i32, 2i32, 3.0);
    aria_tensor_set_2d(ln, 0i32, 3i32, 4.0);
    int64:ln_r = aria_tensor_layer_norm(ln, 0.00001);
    flt64:ln_mean = aria_tensor_mean(ln_r);
    print("Test 10 — LayerNorm mean: ");
    println(string_from_int(@cast<int64>(ln_mean)));
    // After layer norm, mean should be ~0
    if (@cast<int64>(ln_mean) == 0i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 11: Add bias (broadcast) ──
    total += 1i32;
    int64:mat = aria_tensor_create_2d(2i32, 3i32);
    aria_tensor_fill(mat, 1.0);
    int64:bias = aria_tensor_create_1d(3i32);
    aria_tensor_set_1d(bias, 0i32, 10.0);
    aria_tensor_set_1d(bias, 1i32, 20.0);
    aria_tensor_set_1d(bias, 2i32, 30.0);
    int64:biased = aria_tensor_add_bias(mat, bias);
    flt64:b00 = aria_tensor_get_2d(biased, 0i32, 0i32);
    flt64:b02 = aria_tensor_get_2d(biased, 0i32, 2i32);
    flt64:b12 = aria_tensor_get_2d(biased, 1i32, 2i32);
    print("Test 11 — AddBias: [0,0]=");
    print(string_from_int(@cast<int64>(b00)));
    print(" [0,2]=");
    print(string_from_int(@cast<int64>(b02)));
    print(" [1,2]=");
    println(string_from_int(@cast<int64>(b12)));
    // 1+10=11, 1+30=31
    if (@cast<int64>(b00) == 11i64) {
        if (@cast<int64>(b12) == 31i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 12: Min/Max ──
    total += 1i32;
    flt64:mx = aria_tensor_max_val(fr);
    flt64:mn = aria_tensor_min_val(fr);
    print("Test 12 — Range [1..5] max=");
    print(string_from_int(@cast<int64>(mx)));
    print(" min=");
    println(string_from_int(@cast<int64>(mn)));
    if (@cast<int64>(mx) == 5i64) {
        if (@cast<int64>(mn) == 1i64) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Cleanup ──
    aria_tensor_destroy(v);
    aria_tensor_destroy(a);
    aria_tensor_destroy(b);
    aria_tensor_destroy(c);
    aria_tensor_destroy(at);
    aria_tensor_destroy(f);
    aria_tensor_destroy(fr);
    aria_tensor_destroy(rv);
    aria_tensor_destroy(rv_act);
    aria_tensor_destroy(sm);
    aria_tensor_destroy(sm_act);
    aria_tensor_destroy(x);
    aria_tensor_destroy(y);
    aria_tensor_destroy(xy);
    aria_tensor_destroy(xs);
    aria_tensor_destroy(ln);
    aria_tensor_destroy(ln_r);
    aria_tensor_destroy(mat);
    aria_tensor_destroy(bias);
    aria_tensor_destroy(biased);

    // ── Summary ──
    println("");
    print("=== Results: ");
    print(string_from_int(@cast<int64>(passed)));
    print("/");
    print(string_from_int(@cast<int64>(total)));
    println(" passed ===");

    if (passed == total) {
        println("ALL TESTS PASSED");
        exit 0;
    }
    pass 1i32;
};
