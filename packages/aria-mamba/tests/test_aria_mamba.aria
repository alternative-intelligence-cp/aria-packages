// test_aria_mamba.aria — Mamba model test suite
//
// Compile:
//   ariac test_aria_mamba.aria -o test_mamba -L../shim -laria_mamba_shim -lm
// Run:
//   LD_LIBRARY_PATH=../shim ./test_mamba

use "print_utils.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_mamba_shim" {
    func:aria_mamba_last_error     = string();
    func:aria_mamba_set_seed       = void(int32:seed);
    func:aria_mamba_create         = int64(int32:d_model, int32:d_inner, int32:d_state, int32:dt_rank, int32:n_layers, int32:conv_k, int32:vocab_size, int32:max_seq);
    func:aria_mamba_destroy        = void(int64:id);
    func:aria_mamba_d_model        = int32(int64:id);
    func:aria_mamba_d_inner        = int32(int64:id);
    func:aria_mamba_d_state        = int32(int64:id);
    func:aria_mamba_n_layers       = int32(int64:id);
    func:aria_mamba_vocab_size     = int32(int64:id);
    func:aria_mamba_param_count    = int64(int64:id);
    func:aria_mamba_scratch_create = int64(int32:rows, int32:cols);
    func:aria_mamba_scratch_destroy = void(int64:id);
    func:aria_mamba_scratch_set    = void(int64:id, int32:idx, flt64:val);
    func:aria_mamba_scratch_get    = flt64(int64:id, int32:idx);
    func:aria_mamba_scratch_rows   = int32(int64:id);
    func:aria_mamba_scratch_cols   = int32(int64:id);
    func:aria_mamba_forward        = int64(int64:model, int64:input);
    func:aria_mamba_argmax         = int32(int64:scratch, int32:row);
    func:aria_mamba_softmax_row    = void(int64:scratch, int32:row);
}

func:main = int32() {
    int32:passed = 0i32;
    int32:total  = 0i32;

    println("=== aria-mamba test suite ===");
    println("");

    aria_mamba_set_seed(42i32);

    // ── Test 1: Create model ──
    // d_model=16, d_inner=32, d_state=8, dt_rank=4, n_layers=2, conv_k=4, vocab=64, max_seq=16
    total += 1i32;
    int64:model = aria_mamba_create(16i32, 32i32, 8i32, 4i32, 2i32, 4i32, 64i32, 16i32);
    print("Test 1 — Create model: id=");
    println(string_from_int(model));
    if (model >= 0i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 2: Metadata ──
    total += 1i32;
    int32:dm = aria_mamba_d_model(model);
    int32:di = aria_mamba_d_inner(model);
    int32:ds = aria_mamba_d_state(model);
    int32:nl = aria_mamba_n_layers(model);
    int32:vs = aria_mamba_vocab_size(model);
    print("Test 2 — d_model=");
    print(string_from_int(@cast<int64>(dm)));
    print(" d_inner=");
    print(string_from_int(@cast<int64>(di)));
    print(" d_state=");
    print(string_from_int(@cast<int64>(ds)));
    print(" layers=");
    print(string_from_int(@cast<int64>(nl)));
    print(" vocab=");
    println(string_from_int(@cast<int64>(vs)));
    if (dm == 16i32) {
        if (di == 32i32) {
            if (nl == 2i32) {
                println("  PASS");
                passed += 1i32;
            }
        }
    }

    // ── Test 3: Parameter count ──
    total += 1i32;
    int64:params = aria_mamba_param_count(model);
    print("Test 3 — Param count: ");
    println(string_from_int(params));
    if (params > 0i64) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 4: Create input ──
    total += 1i32;
    int64:inp = aria_mamba_scratch_create(4i32, 1i32);
    aria_mamba_scratch_set(inp, 0i32, 1.0);
    aria_mamba_scratch_set(inp, 1i32, 5.0);
    aria_mamba_scratch_set(inp, 2i32, 10.0);
    aria_mamba_scratch_set(inp, 3i32, 3.0);
    int32:ir = aria_mamba_scratch_rows(inp);
    print("Test 4 — Input: rows=");
    println(string_from_int(@cast<int64>(ir)));
    if (ir == 4i32) {
        println("  PASS");
        passed += 1i32;
    }

    // ── Test 5: Forward pass ──
    total += 1i32;
    int64:logits = aria_mamba_forward(model, inp);
    print("Test 5 — Forward pass: logits_id=");
    println(string_from_int(logits));
    if (logits >= 0i64) {
        int32:lr = aria_mamba_scratch_rows(logits);
        int32:lc = aria_mamba_scratch_cols(logits);
        print("  Output shape: [");
        print(string_from_int(@cast<int64>(lr)));
        print(" x ");
        print(string_from_int(@cast<int64>(lc)));
        println("]");
        if (lr == 4i32) {
            if (lc == 64i32) {
                println("  PASS");
                passed += 1i32;
            }
        }
    }

    // ── Test 6: Argmax ──
    total += 1i32;
    int32:pred0 = aria_mamba_argmax(logits, 0i32);
    int32:pred3 = aria_mamba_argmax(logits, 3i32);
    print("Test 6 — Predictions: pos0=");
    print(string_from_int(@cast<int64>(pred0)));
    print(" pos3=");
    println(string_from_int(@cast<int64>(pred3)));
    if (pred0 >= 0i32) {
        if (pred0 < 64i32) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 7: Softmax probabilities ──
    total += 1i32;
    aria_mamba_softmax_row(logits, 0i32);
    flt64:prob_sum = 0.0;
    int32:pi = 0i32;
    for (pi = 0i32; pi < 64i32; pi += 1i32) {
        prob_sum = prob_sum + aria_mamba_scratch_get(logits, pi);
    }
    print("Test 7 — Softmax row sum=");
    println(string_from_int(@cast<int64>(prob_sum * 1000.0)));
    if (prob_sum > 0.99) {
        if (prob_sum < 1.01) {
            println("  PASS");
            passed += 1i32;
        }
    }

    // ── Test 8: Causal property — different position sees different context ──
    total += 1i32;
    // Run forward twice with different inputs; first 2 tokens same, 3rd differs
    int64:inp2 = aria_mamba_scratch_create(4i32, 1i32);
    aria_mamba_scratch_set(inp2, 0i32, 1.0);
    aria_mamba_scratch_set(inp2, 1i32, 5.0);
    aria_mamba_scratch_set(inp2, 2i32, 20.0);
    aria_mamba_scratch_set(inp2, 3i32, 3.0);
    int64:logits2 = aria_mamba_forward(model, inp2);
    if (logits2 >= 0i64) {
        // Position 3 should differ (sees different token at pos 2)
        int32:p2_a = aria_mamba_argmax(logits, 3i32);
        int32:p2_b = aria_mamba_argmax(logits2, 3i32);
        print("Test 8 — Causal sensitivity: pred_a=");
        print(string_from_int(@cast<int64>(p2_a)));
        print(" pred_b=");
        println(string_from_int(@cast<int64>(p2_b)));
        // Just check output is valid (both should be valid token IDs)
        if (p2_b >= 0i32) {
            if (p2_b < 64i32) {
                println("  PASS");
                passed += 1i32;
            }
        }
        aria_mamba_scratch_destroy(logits2);
    }
    aria_mamba_scratch_destroy(inp2);

    // ── Test 9: Longer sequence ──
    total += 1i32;
    int64:inp3 = aria_mamba_scratch_create(12i32, 1i32);
    int32:si = 0i32;
    for (si = 0i32; si < 12i32; si += 1i32) {
        aria_mamba_scratch_set(inp3, si, @cast<flt64>(si) * 3.0);
    }
    int64:logits3 = aria_mamba_forward(model, inp3);
    print("Test 9 — Longer sequence (len=12): ");
    if (logits3 >= 0i64) {
        int32:lr3 = aria_mamba_scratch_rows(logits3);
        int32:lc3 = aria_mamba_scratch_cols(logits3);
        print("[");
        print(string_from_int(@cast<int64>(lr3)));
        print(" x ");
        print(string_from_int(@cast<int64>(lc3)));
        println("]");
        if (lr3 == 12i32) {
            if (lc3 == 64i32) {
                println("  PASS");
                passed += 1i32;
            }
        }
        aria_mamba_scratch_destroy(logits3);
    }
    aria_mamba_scratch_destroy(inp3);

    // ── Test 10: Larger model ──
    total += 1i32;
    int64:big = aria_mamba_create(32i32, 64i32, 16i32, 8i32, 4i32, 4i32, 128i32, 32i32);
    print("Test 10 — Larger model (d=32 inner=64 state=16 L=4 V=128): ");
    if (big >= 0i64) {
        int64:bp = aria_mamba_param_count(big);
        print("params=");
        println(string_from_int(bp));
        int64:binp = aria_mamba_scratch_create(8i32, 1i32);
        int32:bi = 0i32;
        for (bi = 0i32; bi < 8i32; bi += 1i32) {
            aria_mamba_scratch_set(binp, bi, @cast<flt64>(bi) * 5.0);
        }
        int64:bout = aria_mamba_forward(big, binp);
        if (bout >= 0i64) {
            int32:br = aria_mamba_scratch_rows(bout);
            int32:bc = aria_mamba_scratch_cols(bout);
            if (br == 8i32) {
                if (bc == 128i32) {
                    println("  PASS");
                    passed += 1i32;
                }
            }
            aria_mamba_scratch_destroy(bout);
        }
        aria_mamba_scratch_destroy(binp);
        aria_mamba_destroy(big);
    }

    // ── Cleanup ──
    aria_mamba_scratch_destroy(logits);
    aria_mamba_scratch_destroy(inp);
    aria_mamba_destroy(model);

    // ── Summary ──
    println("");
    print("=== Results: ");
    print(string_from_int(@cast<int64>(passed)));
    print("/");
    print(string_from_int(@cast<int64>(total)));
    println(" passed ===");

    if (passed == total) {
        println("ALL TESTS PASSED");
        exit 0;
    }
    pass 1i32;
};
