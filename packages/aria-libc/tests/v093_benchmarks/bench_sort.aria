/* Benchmark: aria-sort pure Aria quicksort vs insertion sort
 *
 * v0.9.3 — Measures pure Aria sort performance with varying sizes.
 */

func:failsafe = int32(tbb32:err) { exit 1; };

extern "aria_libc_time" {
    func:aria_libc_time_monotonic_ns = int64();
}

extern "aria_libc_mem" {
    func:aria_libc_mem_malloc    = int64(int64:size);
    func:aria_libc_mem_realloc   = int64(int64:ptr, int64:size);
    func:aria_libc_mem_free      = void(int64:ptr);
    func:aria_libc_mem_read_i64  = int64(int64:ptr, int64:offset);
    func:aria_libc_mem_write_i64 = void(int64:ptr, int64:offset, int64:val);
}

// ── Inline sort helpers (same as aria-sort) ─────────────────────

func:_arr_get_data = int64(int64:arr) { pass aria_libc_mem_read_i64(arr, 0i64); };
func:_arr_get_len = int64(int64:arr) { pass aria_libc_mem_read_i64(arr, 8i64); };
func:_arr_get_cap = int64(int64:arr) { pass aria_libc_mem_read_i64(arr, 16i64); };

func:_arr_set_len = NIL(int64:arr, int64:len) {
    drop aria_libc_mem_write_i64(arr, 8i64, len);
    pass NIL;
};

func:_elem_get = int64(int64:data, int64:idx) {
    pass aria_libc_mem_read_i64(data, idx * 8i64);
};

func:_elem_set = NIL(int64:data, int64:idx, int64:val) {
    drop aria_libc_mem_write_i64(data, idx * 8i64, val);
    pass NIL;
};

func:_elem_swap = NIL(int64:data, int64:i, int64:j) {
    int64:a = raw _elem_get(data, i);
    int64:b = raw _elem_get(data, j);
    drop _elem_set(data, i, b);
    drop _elem_set(data, j, a);
    pass NIL;
};

func:arr_new = int64() {
    int64:arr = aria_libc_mem_malloc(24i64);
    int64:cap = 1024i64;
    int64:data = aria_libc_mem_malloc(cap * 8i64);
    drop aria_libc_mem_write_i64(arr, 0i64, data);
    drop aria_libc_mem_write_i64(arr, 8i64, 0i64);
    drop aria_libc_mem_write_i64(arr, 16i64, cap);
    pass arr;
};

func:arr_push = NIL(int64:arr, int64:val) {
    int64:len = raw _arr_get_len(arr);
    int64:cap = raw _arr_get_cap(arr);
    if (len >= cap) {
        int64:nc = cap * 2i64;
        int64:data = raw _arr_get_data(arr);
        int64:nd = aria_libc_mem_realloc(data, nc * 8i64);
        drop aria_libc_mem_write_i64(arr, 0i64, nd);
        drop aria_libc_mem_write_i64(arr, 16i64, nc);
    }
    int64:data = raw _arr_get_data(arr);
    drop _elem_set(data, len, val);
    drop _arr_set_len(arr, len + 1i64);
    pass NIL;
};

func:arr_free = NIL(int64:arr) {
    int64:data = raw _arr_get_data(arr);
    drop aria_libc_mem_free(data);
    drop aria_libc_mem_free(arr);
    pass NIL;
};

// ── Quicksort ───────────────────────────────────────────────────

func:_qs_partition = int64(int64:data, int64:lo, int64:hi) {
    int64:pivot = raw _elem_get(data, hi);
    int64:i = lo - 1i64;
    int64:j = lo;
    while (j < hi) {
        int64:val = raw _elem_get(data, j);
        if (val <= pivot) { i = i + 1i64; drop _elem_swap(data, i, j); }
        j = j + 1i64;
    }
    i = i + 1i64;
    drop _elem_swap(data, i, hi);
    pass i;
};

func:_qs_recurse = NIL(int64:data, int64:lo, int64:hi) {
    if (lo < hi) {
        int64:p = raw _qs_partition(data, lo, hi);
        drop _qs_recurse(data, lo, p - 1i64);
        drop _qs_recurse(data, p + 1i64, hi);
    }
    pass NIL;
};

func:quicksort = NIL(int64:arr) {
    int64:len = raw _arr_get_len(arr);
    if (len > 1i64) {
        int64:data = raw _arr_get_data(arr);
        drop _qs_recurse(data, 0i64, len - 1i64);
    }
    pass NIL;
};

// ── Insertion sort ──────────────────────────────────────────────

func:insertion_sort = NIL(int64:arr) {
    int64:len = raw _arr_get_len(arr);
    int64:data = raw _arr_get_data(arr);
    int64:i = 1i64;
    while (i < len) {
        int64:key = raw _elem_get(data, i);
        int64:j = i - 1i64;
        bool:shifting = true;
        while (shifting) {
            if (j < 0i64) { shifting = false; } else {
                int64:jval = raw _elem_get(data, j);
                if (jval > key) {
                    drop _elem_set(data, j + 1i64, jval);
                    j = j - 1i64;
                } else { shifting = false; }
            }
        }
        drop _elem_set(data, j + 1i64, key);
        i = i + 1i64;
    }
    pass NIL;
};

// ── Simple LCG PRNG ─────────────────────────────────────────────

func:lcg_next = int64(int64:state) {
    // LCG: state = state * 6364136223846793005 + 1442695040888963407
    // Simplified to avoid overflow issues — use smaller multiplier
    int64:r = state * 1103515245i64 + 12345i64;
    // Mask to positive
    if (r < 0i64) { r = 0i64 - r; }
    pass r;
};

func:fill_random = NIL(int64:arr, int64:count) {
    int64:state = 42i64;
    int64:i = 0i64;
    while (i < count) {
        state = raw lcg_next(state);
        drop arr_push(arr, state);
        i = i + 1i64;
    }
    pass NIL;
};

func:report = NIL(string:label, int64:ns) {
    int64:us = ns / 1000i64;
    print("  ");
    print(label);
    print(": ");
    print(string_from_int(us));
    println(" us");
};

func:main = int32() {
    println("=== v0.9.3 Performance Benchmarks: Sort (pure Aria) ===");

    // ── 100 elements ────────────────────────────────────
    println("--- 100 elements ---");
    int64:arr1 = raw arr_new();
    drop fill_random(arr1, 100i64);
    int64:t0 = aria_libc_time_monotonic_ns();
    drop quicksort(arr1);
    int64:t1 = aria_libc_time_monotonic_ns();
    drop report("quicksort 100 ", t1 - t0);
    drop arr_free(arr1);

    int64:arr2 = raw arr_new();
    drop fill_random(arr2, 100i64);
    int64:t2 = aria_libc_time_monotonic_ns();
    drop insertion_sort(arr2);
    int64:t3 = aria_libc_time_monotonic_ns();
    drop report("insertion 100 ", t3 - t2);
    drop arr_free(arr2);

    // ── 1,000 elements ──────────────────────────────────
    println("--- 1000 elements ---");
    int64:arr3 = raw arr_new();
    drop fill_random(arr3, 1000i64);
    int64:t4 = aria_libc_time_monotonic_ns();
    drop quicksort(arr3);
    int64:t5 = aria_libc_time_monotonic_ns();
    drop report("quicksort 1k  ", t5 - t4);
    drop arr_free(arr3);

    int64:arr4 = raw arr_new();
    drop fill_random(arr4, 1000i64);
    int64:t6 = aria_libc_time_monotonic_ns();
    drop insertion_sort(arr4);
    int64:t7 = aria_libc_time_monotonic_ns();
    drop report("insertion 1k  ", t7 - t6);
    drop arr_free(arr4);

    // ── 10,000 elements ─────────────────────────────────
    println("--- 10000 elements ---");
    int64:arr5 = raw arr_new();
    drop fill_random(arr5, 10000i64);
    int64:t8 = aria_libc_time_monotonic_ns();
    drop quicksort(arr5);
    int64:t9 = aria_libc_time_monotonic_ns();
    drop report("quicksort 10k ", t9 - t8);
    drop arr_free(arr5);

    // Skip insertion sort at 10k — too slow (O(n^2))
    println("  insertion 10k : skipped (O(n^2))");

    // ── 50,000 elements ─────────────────────────────────
    println("--- 50000 elements ---");
    int64:arr6 = raw arr_new();
    drop fill_random(arr6, 50000i64);
    int64:t10 = aria_libc_time_monotonic_ns();
    drop quicksort(arr6);
    int64:t11 = aria_libc_time_monotonic_ns();
    drop report("quicksort 50k ", t11 - t10);
    drop arr_free(arr6);

    println("=== Done ===");
    exit 0;
};
