pub func:math_fmin = flt64(flt64:a, flt64:b) {
    flt64:r = aria_libc_math_fmin(a, b);
    pass r;
}

pub func:math_fmax = flt64(flt64:a, flt64:b) {
    flt64:r = aria_libc_math_fmax(a, b);
