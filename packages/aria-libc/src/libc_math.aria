/* aria-libc :: math — Math functions
 * Wraps: sin, cos, sqrt, pow, log, exp, floor, ceil, fmod, etc.
 */

extern "aria_libc_math" {
    func:aria_libc_math_sin     = flt64(flt64:x);
    func:aria_libc_math_cos     = flt64(flt64:x);
    func:aria_libc_math_tan     = flt64(flt64:x);
    func:aria_libc_math_asin    = flt64(flt64:x);
    func:aria_libc_math_acos    = flt64(flt64:x);
    func:aria_libc_math_atan    = flt64(flt64:x);
    func:aria_libc_math_atan2   = flt64(flt64:y, flt64:x);

    func:aria_libc_math_sinh    = flt64(flt64:x);
    func:aria_libc_math_cosh    = flt64(flt64:x);
    func:aria_libc_math_tanh    = flt64(flt64:x);

    func:aria_libc_math_exp     = flt64(flt64:x);
    func:aria_libc_math_exp2    = flt64(flt64:x);
    func:aria_libc_math_log     = flt64(flt64:x);
    func:aria_libc_math_log2    = flt64(flt64:x);
    func:aria_libc_math_log10   = flt64(flt64:x);

    func:aria_libc_math_pow     = flt64(flt64:base, flt64:exp_val);
    func:aria_libc_math_sqrt    = flt64(flt64:x);
    func:aria_libc_math_cbrt    = flt64(flt64:x);
    func:aria_libc_math_hypot   = flt64(flt64:x, flt64:y);

    func:aria_libc_math_floor   = flt64(flt64:x);
    func:aria_libc_math_ceil    = flt64(flt64:x);
    func:aria_libc_math_round   = flt64(flt64:x);
    func:aria_libc_math_trunc   = flt64(flt64:x);
    func:aria_libc_math_fmod    = flt64(flt64:x, flt64:y);

    func:aria_libc_math_fabs    = flt64(flt64:x);
    func:aria_libc_math_copysign = flt64(flt64:mag, flt64:sgn);
    func:aria_libc_math_fma     = flt64(flt64:a, flt64:b, flt64:c);

    func:aria_libc_math_fmin    = flt64(flt64:a, flt64:b);
    func:aria_libc_math_fmax    = flt64(flt64:a, flt64:b);
    func:aria_libc_math_min_i64 = int64(int64:a, int64:b);
    func:aria_libc_math_max_i64 = int64(int64:a, int64:b);
    func:aria_libc_math_abs_i64 = int64(int64:x);

    func:aria_libc_math_isnan    = int32(flt64:x);
    func:aria_libc_math_isinf    = int32(flt64:x);
    func:aria_libc_math_isfinite = int32(flt64:x);

    func:aria_libc_math_pi      = flt64();
    func:aria_libc_math_e       = flt64();
    func:aria_libc_math_inf     = flt64();
    func:aria_libc_math_nan     = flt64();
    func:aria_libc_math_epsilon = flt64();
}

/* ── Trigonometric ───────────────────────────────────────────────── */

pub func:math_sin = flt64(flt64:x) {
    flt64:r = aria_libc_math_sin(x);
    pass r;
}

pub func:math_cos = flt64(flt64:x) {
    flt64:r = aria_libc_math_cos(x);
    pass r;
}

pub func:math_tan = flt64(flt64:x) {
    flt64:r = aria_libc_math_tan(x);
    pass r;
}

pub func:math_asin = flt64(flt64:x) {
    flt64:r = aria_libc_math_asin(x);
    pass r;
}

pub func:math_acos = flt64(flt64:x) {
    flt64:r = aria_libc_math_acos(x);
    pass r;
}

pub func:math_atan = flt64(flt64:x) {
    flt64:r = aria_libc_math_atan(x);
    pass r;
}

pub func:math_atan2 = flt64(flt64:y, flt64:x) {
    flt64:r = aria_libc_math_atan2(y, x);
    pass r;
}

