/* ── Power / Root ────────────────────────────────────────────────── */

pub func:math_pow = flt64(flt64:base, flt64:exp_val) {
    flt64:r = aria_libc_math_pow(base, exp_val);
    pass r;
}

pub func:math_sqrt = flt64(flt64:x) {
    flt64:r = aria_libc_math_sqrt(x);
    pass r;
}

pub func:math_cbrt = flt64(flt64:x) {
    flt64:r = aria_libc_math_cbrt(x);
    pass r;
}

pub func:math_hypot = flt64(flt64:x, flt64:y) {
    flt64:r = aria_libc_math_hypot(x, y);
    pass r;
}

/* ── Rounding ────────────────────────────────────────────────────── */

pub func:math_floor = flt64(flt64:x) {
    flt64:r = aria_libc_math_floor(x);
    pass r;
}

pub func:math_ceil = flt64(flt64:x) {
    flt64:r = aria_libc_math_ceil(x);
