/* ── Absolute / Sign ─────────────────────────────────────────────── */

pub func:math_abs = flt64(flt64:x) {
    flt64:r = aria_libc_math_fabs(x);
    pass r;
}

pub func:math_copysign = flt64(flt64:mag, flt64:sgn) {
    flt64:r = aria_libc_math_copysign(mag, sgn);
    pass r;
}

pub func:math_fma = flt64(flt64:a, flt64:b, flt64:c) {
    flt64:r = aria_libc_math_fma(a, b, c);
    pass r;
}

