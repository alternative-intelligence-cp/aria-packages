pub func:math_min = int64(int64:a, int64:b) {
    int64:r = aria_libc_math_min_i64(a, b);
    pass r;
}

pub func:math_max = int64(int64:a, int64:b) {
    int64:r = aria_libc_math_max_i64(a, b);
    pass r;
}

pub func:math_abs_int = int64(int64:x) {
    int64:r = aria_libc_math_abs_i64(x);
    pass r;
}

/* ── Classification ──────────────────────────────────────────────── */

pub func:math_is_nan = int32(flt64:x) {
    int32:r = aria_libc_math_isnan(x);
    pass r;
}

pub func:math_is_inf = int32(flt64:x) {
    int32:r = aria_libc_math_isinf(x);
    pass r;
}

pub func:math_is_finite = int32(flt64:x) {
    int32:r = aria_libc_math_isfinite(x);
    pass r;
}

/* ── Constants ───────────────────────────────────────────────────── */

pub func:math_PI = flt64() {
    flt64:v = aria_libc_math_pi();
    pass v;
}

pub func:math_E = flt64() {
    flt64:v = aria_libc_math_e();
    pass v;
}

pub func:math_INF = flt64() {
    flt64:v = aria_libc_math_inf();
    pass v;
}

pub func:math_NAN = flt64() {
    flt64:v = aria_libc_math_nan();
    pass v;
}

pub func:math_EPSILON = flt64() {
    flt64:v = aria_libc_math_epsilon();
    pass v;
}

func:failsafe = int32(tbb32:err) { exit 1; };
