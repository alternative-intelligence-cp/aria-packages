    flt64:r = aria_libc_math_exp(x);
    pass r;
}

pub func:math_exp2 = flt64(flt64:x) {
    flt64:r = aria_libc_math_exp2(x);
    pass r;
}

pub func:math_log = flt64(flt64:x) {
    flt64:r = aria_libc_math_log(x);
    pass r;
}

pub func:math_log2 = flt64(flt64:x) {
    flt64:r = aria_libc_math_log2(x);
    pass r;
}

pub func:math_log10 = flt64(flt64:x) {
    flt64:r = aria_libc_math_log10(x);
    pass r;
