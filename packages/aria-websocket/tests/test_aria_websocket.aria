// test_aria_websocket.aria — 12-test suite for aria-websocket (v0.12.2)
use "../src/aria_websocket.aria".*;

func:failsafe = int32(tbb32:err_code) { exit 1i32; };

func:test_create_handshake = int32() {
    int32:pc = 0i32;

    int64:ws = raw ws_create("example.com", "/chat");
    if (ws > 0i64) { println("[PASS] T01 ws_create"); pc += 1i32; }
    if (ws <= 0i64) { println("[FAIL] T01"); }

    string:req = raw ws_handshake_request(ws);
    int32:t2 = 0i32;
    if (string_contains(req, "GET /chat")) { t2 = 1i32; }
    if (t2 == 1i32) { println("[PASS] T02 handshake GET path"); pc += 1i32; }
    if (t2 == 0i32) { println("[FAIL] T02"); }

    int32:t3 = 0i32;
    if (string_contains(req, "Upgrade: websocket")) { t3 = 1i32; }
    if (t3 == 1i32) { println("[PASS] T03 handshake Upgrade header"); pc += 1i32; }
    if (t3 == 0i32) { println("[FAIL] T03"); }

    pass pc;
};

func:test_handshake_state = int32() {
    int32:pc = 0i32;

    int64:ws = raw ws_create("example.com", "/chat");

    string:req = raw ws_handshake_request(ws);
    int32:t4 = 0i32;
    if (string_contains(req, "Host: example.com")) { t4 = 1i32; }
    if (t4 == 1i32) { println("[PASS] T04 handshake Host header"); pc += 1i32; }
    if (t4 == 0i32) { println("[FAIL] T04"); }

    string:st5 = raw ws_state(ws);
    int32:t5 = 0i32;
    if (string_contains(st5, "connecting")) { t5 = 1i32; }
    if (t5 == 1i32) { println("[PASS] T05 initial state=connecting"); pc += 1i32; }
    if (t5 == 0i32) { println("[FAIL] T05"); }

    int32:_s = raw ws_set_state(ws, "open");
    string:st6 = raw ws_state(ws);
    int32:t6 = 0i32;
    if (string_contains(st6, "open")) { t6 = 1i32; }
    if (t6 == 1i32) { println("[PASS] T06 set_state open"); pc += 1i32; }
    if (t6 == 0i32) { println("[FAIL] T06"); }

    pass pc;
};

func:test_frame_types = int32() {
    int32:pc = 0i32;

    string:f7 = raw ws_frame_type_name(1i64);
    int32:t7 = 0i32;
    if (string_contains(f7, "text")) { t7 = 1i32; }
    if (t7 == 1i32) { println("[PASS] T07 frame_type 1=text"); pc += 1i32; }
    if (t7 == 0i32) { println("[FAIL] T07"); }

    string:f8 = raw ws_frame_type_name(2i64);
    int32:t8 = 0i32;
    if (string_contains(f8, "binary")) { t8 = 1i32; }
    if (t8 == 1i32) { println("[PASS] T08 frame_type 2=binary"); pc += 1i32; }
    if (t8 == 0i32) { println("[FAIL] T08"); }

    string:f9 = raw ws_frame_type_name(8i64);
    int32:t9 = 0i32;
    if (string_contains(f9, "close")) { t9 = 1i32; }
    if (t9 == 1i32) { println("[PASS] T09 frame_type 8=close"); pc += 1i32; }
    if (t9 == 0i32) { println("[FAIL] T09"); }

    pass pc;
};

func:test_close_accessors = int32() {
    int32:pc = 0i32;

    int64:ws = raw ws_create("example.com", "/chat");

    string:f10 = raw ws_frame_type_name(9i64);
    int32:t10 = 0i32;
    if (string_contains(f10, "ping")) { t10 = 1i32; }
    if (t10 == 1i32) { println("[PASS] T10 frame_type 9=ping"); pc += 1i32; }
    if (t10 == 0i32) { println("[FAIL] T10"); }

    string:h11 = raw ws_host(ws);
    int32:t11 = 0i32;
    if (string_contains(h11, "example.com")) { t11 = 1i32; }
    if (t11 == 1i32) { println("[PASS] T11 ws_host"); pc += 1i32; }
    if (t11 == 0i32) { println("[FAIL] T11"); }

    string:p12 = raw ws_path(ws);
    int32:t12 = 0i32;
    if (string_contains(p12, "/chat")) { t12 = 1i32; }
    if (t12 == 1i32) { println("[PASS] T12 ws_path"); pc += 1i32; }
    if (t12 == 0i32) { println("[FAIL] T12"); }

    pass pc;
};

func:main = int32() {
    int32:p1 = raw test_create_handshake();
    int32:p2 = raw test_handshake_state();
    int32:p3 = raw test_frame_types();
    int32:p4 = raw test_close_accessors();
    println("DONE");
    exit(0i32);
};
