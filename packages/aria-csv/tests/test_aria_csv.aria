// test_aria_csv.aria — Parse tests for aria-csv (pure Aria, 15 tests)

use "../src/aria_csv.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:_check_int = NIL(int32:got, int32:expected, string:label) {
    if (got == expected) { drop println(label); }
    if (got != expected) {
        drop print("[FAIL instead of ");
        drop print(label);
        drop println("]");
    }
    pass NIL;
};

func:_check_field = NIL(int32:row, int32:col_p, string:expected, string:label) {
    string:got = raw csv_get(row, col_p);
    int32:c = aria_libc_string_strcmp(got, expected);
    if (c == 0i32) { drop println(label); }
    if (c != 0i32) {
        drop print("[FAIL instead of ");
        drop print(label);
        drop print("] got=");
        drop println(got);
    }
    pass NIL;
};

func:main = int32() {
    // T01: parse simple CSV
    int32:rows = raw csv_parse("name,age,city\nAlice,30,NYC\nBob,25,LA\n");
    drop _check_int(rows, 3i32, "[PASS] T01 parsed 3 rows");

    // T02: num_cols
    int32:cols = raw csv_num_cols();
    drop _check_int(cols, 3i32, "[PASS] T02 3 columns");

    // T03-05: header fields
    drop _check_field(0i32, 0i32, "name", "[PASS] T03 header[0]=name");
    drop _check_field(0i32, 1i32, "age", "[PASS] T04 header[1]=age");
    drop _check_field(0i32, 2i32, "city", "[PASS] T05 header[2]=city");

    // T06-07: data row 1
    drop _check_field(1i32, 0i32, "Alice", "[PASS] T06 row1[0]=Alice");
    drop _check_field(1i32, 1i32, "30", "[PASS] T07 row1[1]=30");

    // T08-09: data row 2
    drop _check_field(2i32, 0i32, "Bob", "[PASS] T08 row2[0]=Bob");
    drop _check_field(2i32, 2i32, "LA", "[PASS] T09 row2[2]=LA");

    // T10-11: quoted field with comma
    int32:qrows = raw csv_parse("a,\"b,c\",d\n");
    drop _check_int(qrows, 1i32, "[PASS] T10 quoted CSV 1 row");
    drop _check_field(0i32, 1i32, "b,c", "[PASS] T11 quoted field=b,c");

    // T12: empty input
    int32:erows = raw csv_parse("");
    drop _check_int(erows, 0i32, "[PASS] T12 empty input 0 rows");

    // T13-14: single field
    int32:sf = raw csv_parse("hello\n");
    drop _check_int(sf, 1i32, "[PASS] T13 single field 1 row");
    drop _check_field(0i32, 0i32, "hello", "[PASS] T14 single field=hello");

    // T15: multi-row count
    int32:mr = raw csv_parse("a\nb\nc\nd\n");
    drop _check_int(mr, 4i32, "[PASS] T15 multi-row 4 rows");

    drop csv_cleanup();

    exit 0;
};
