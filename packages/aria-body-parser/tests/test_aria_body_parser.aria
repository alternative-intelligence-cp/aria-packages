// test_aria_body_parser.aria — Tests for body parsing
// Tests JSON, form-urlencoded, and raw body handling.

func:failsafe = NIL(int32:code) { pass(NIL); };

extern "aria_body_parser_shim" {
    func:aria_body_parser_detect       = int32(string:content_type);
    func:aria_body_parser_parse        = int32(string:body, string:content_type);
    func:aria_body_parser_field        = string(string:key);
    func:aria_body_parser_has_field    = int32(string:key);
    func:aria_body_parser_field_count  = int32();
    func:aria_body_parser_field_key    = string(int32:index);
    func:aria_body_parser_field_value  = string(int32:index);
    func:aria_body_parser_content_type = int32();
    func:aria_body_parser_raw          = string();
    func:aria_body_parser_raw_length   = int32();
    func:aria_body_parser_error        = string();
    func:aria_body_parser_reset        = void();
    func:aria_body_parser_assert_str_eq = void(string:label, string:expected, string:actual);
    func:aria_body_parser_assert_int_eq = void(string:label, int32:expected, int32:actual);
    func:aria_body_parser_test_summary  = void();
}

func:main = int32() {
    // ── Test 1: Content-type detection ──
    int32:ct1 = aria_body_parser_detect("application/json");
    aria_body_parser_assert_int_eq("detect json", 1i32, ct1);

    int32:ct2 = aria_body_parser_detect("application/x-www-form-urlencoded");
    aria_body_parser_assert_int_eq("detect form", 2i32, ct2);

    int32:ct3 = aria_body_parser_detect("text/plain");
    aria_body_parser_assert_int_eq("detect text", 4i32, ct3);

    int32:ct4 = aria_body_parser_detect("application/octet-stream");
    aria_body_parser_assert_int_eq("detect unknown", 0i32, ct4);

    // ── Test 2: JSON parsing ──
    int32:n1 = aria_body_parser_parse("{\"name\":\"aria\",\"version\":\"0.2.9\",\"active\":true,\"count\":42}", "application/json");
    aria_body_parser_assert_int_eq("json field count", 4i32, n1);
    aria_body_parser_assert_int_eq("json content type", 1i32, aria_body_parser_content_type());

    string:v1 = aria_body_parser_field("name");
    aria_body_parser_assert_str_eq("json field name", "aria", v1);

    string:v2 = aria_body_parser_field("version");
    aria_body_parser_assert_str_eq("json field version", "0.2.9", v2);

    string:v3 = aria_body_parser_field("active");
    aria_body_parser_assert_str_eq("json field bool", "true", v3);

    string:v4 = aria_body_parser_field("count");
    aria_body_parser_assert_str_eq("json field number", "42", v4);

    int32:hf1 = aria_body_parser_has_field("name");
    aria_body_parser_assert_int_eq("has_field name", 1i32, hf1);

    int32:hf2 = aria_body_parser_has_field("missing");
    aria_body_parser_assert_int_eq("has_field missing", 0i32, hf2);

    // ── Test 3: JSON with nested object ──
    aria_body_parser_reset();
    int32:n2 = aria_body_parser_parse("{\"user\":{\"id\":1,\"name\":\"Bob\"},\"ok\":true}", "application/json");
    aria_body_parser_assert_int_eq("nested json count", 2i32, n2);

    string:nested = aria_body_parser_field("user");
    aria_body_parser_assert_str_eq("nested object", "{\"id\":1,\"name\":\"Bob\"}", nested);

    // ── Test 4: Form-urlencoded parsing ──
    aria_body_parser_reset();
    int32:n3 = aria_body_parser_parse("username=aria&password=secret&remember=1", "application/x-www-form-urlencoded");
    aria_body_parser_assert_int_eq("form field count", 3i32, n3);
    aria_body_parser_assert_int_eq("form content type", 2i32, aria_body_parser_content_type());

    string:fu = aria_body_parser_field("username");
    aria_body_parser_assert_str_eq("form username", "aria", fu);

    string:fp = aria_body_parser_field("password");
    aria_body_parser_assert_str_eq("form password", "secret", fp);

    // ── Test 5: URL-decoded form values ──
    aria_body_parser_reset();
    int32:n4 = aria_body_parser_parse("q=hello+world&tag=%23aria", "application/x-www-form-urlencoded");
    aria_body_parser_assert_int_eq("decoded form count", 2i32, n4);

    string:dq = aria_body_parser_field("q");
    aria_body_parser_assert_str_eq("decoded space", "hello world", dq);

    string:dt = aria_body_parser_field("tag");
    aria_body_parser_assert_str_eq("decoded percent", "#aria", dt);

    // ── Test 6: Raw body (text/plain) ──
    aria_body_parser_reset();
    int32:n5 = aria_body_parser_parse("Just some plain text.", "text/plain");
    aria_body_parser_assert_int_eq("text field count", 0i32, n5);

    string:rbody = aria_body_parser_raw();
    aria_body_parser_assert_str_eq("raw body", "Just some plain text.", rbody);

    int32:rl = aria_body_parser_raw_length();
    aria_body_parser_assert_int_eq("raw length", 21i32, rl);

    // ── Test 7: Field iteration by index ──
    aria_body_parser_reset();
    int32:n6 = aria_body_parser_parse("{\"a\":\"1\",\"b\":\"2\"}", "application/json");
    string:k0 = aria_body_parser_field_key(0i32);
    aria_body_parser_assert_str_eq("key 0", "a", k0);
    string:val0 = aria_body_parser_field_value(0i32);
    aria_body_parser_assert_str_eq("val 0", "1", val0);
    string:k1 = aria_body_parser_field_key(1i32);
    aria_body_parser_assert_str_eq("key 1", "b", k1);

    // ── Test 8: Empty body ──
    aria_body_parser_reset();
    int32:n7 = aria_body_parser_parse("", "application/json");
    aria_body_parser_assert_int_eq("empty json error", -1i32, n7);

    aria_body_parser_test_summary();
    pass(0i32);
};
