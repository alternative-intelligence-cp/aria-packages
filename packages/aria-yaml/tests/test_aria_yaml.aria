// test_aria_yaml.aria — YAML parser tests (pure Aria)
use "../src/aria_yaml.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    println("=== aria-yaml tests ===");

    int32:n = raw yaml_parse("name: MyApp\nversion: 3\ndebug_mode: true\npi: 3.14\n\nserver:\n  host: localhost\n  port: 8080\n\ndatabase:\n  name: mydb\n  enabled: false\n");

    // T01: parse returns positive count
    if (n > 0i32) { println("  PASS: T01 parse"); }
    else { println("  FAIL: T01 parse"); }

    // T02: top-level has_key
    int32:h1 = raw yaml_has_key("name");
    if (h1 == 1i32) { println("  PASS: T02 has_key name"); }
    else { println("  FAIL: T02 has_key name"); }

    // T03: top-level int
    int64:ver = raw yaml_get_int("version");
    if (ver == 3i64) { println("  PASS: T03 get_int version"); }
    else { println("  FAIL: T03 get_int version"); }

    // T04: bool true
    int32:dbg_mode = raw yaml_get_bool("debug_mode");
    if (dbg_mode == 1i32) { println("  PASS: T04 get_bool debug_mode"); }
    else { println("  FAIL: T04 get_bool debug_mode"); }

    // T05: nested int
    int64:port = raw yaml_get_int("server.port");
    if (port == 8080i64) { println("  PASS: T05 get_int server.port"); }
    else { println("  FAIL: T05 get_int server.port"); }

    // T06: nested bool false
    int32:en = raw yaml_get_bool("database.enabled");
    if (en == 0i32) { println("  PASS: T06 get_bool database.enabled"); }
    else { println("  FAIL: T06 get_bool database.enabled"); }

    // T07: missing key
    int32:miss = raw yaml_has_key("nonexistent");
    if (miss == 0i32) { println("  PASS: T07 missing key"); }
    else { println("  FAIL: T07 missing key"); }

    // T08: clear
    drop yaml_clear();
    int32:c2 = raw yaml_count();
    if (c2 == 0i32) { println("  PASS: T08 clear"); }
    else { println("  FAIL: T08 clear"); }

    println("=== 8 tests done ===");
    exit 0;
};
